<Application x:Class="Clinica.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Clinica.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Ordem importa: tokens → compatibilidade → estilos → componentes. -->
                <ResourceDictionary Source="Styles/Tokens.xaml" />
                <ResourceDictionary Source="Styles/Compat.xaml" />
                <ResourceDictionary Source="Styles/Theme.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Botoes.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Campos.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Selecao.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Tabelas.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Navegacao.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Feedback.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Sobreposicao.xaml" />
                <ResourceDictionary Source="Styles/Componentes/Cartoes.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:UrgenciaParaCorConverter x:Key="UrgenciaParaCor" />
            <conv:EnumDescricaoConverter x:Key="EnumDescricao" />
            <conv:CpfConverter x:Key="Cpf" />
            <conv:StatusCodigoConverter x:Key="StatusCodigo" />
            <BooleanToVisibilityConverter x:Key="BoolParaVisibilidade" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
