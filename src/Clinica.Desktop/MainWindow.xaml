<Window x:Class="Clinica.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Clinica.Desktop.ViewModels"
        xmlns:views="clr-namespace:Clinica.Desktop.Views"
        Title="Clínica — Faturamento" Height="740" Width="1180"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        Background="{StaticResource BrushFundo}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PacientesViewModel}">
            <views:PacientesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NovoAtendimentoViewModel}">
            <views:NovoAtendimentoView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BaixaViewModel}">
            <views:BaixaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
            <views:RelatoriosView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FaturadosViewModel}">
            <views:FaturadosView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FichaPacienteViewModel}">
            <views:FichaPacienteView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AgendaViewModel}">
            <views:AgendaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GlosasViewModel}">
            <views:GlosasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TissViewModel}">
            <views:TissView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Menu lateral -->
        <Border Grid.Column="0" Background="#14532D">
            <StackPanel Margin="16">
                <TextBlock Text="CLÍNICA" Foreground="White" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="Faturamento" Foreground="#A7F3D0" FontSize="13" Margin="0,0,0,24" />

                <Button Content="📋  Pendências" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarDashboardCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Pendencias}" />
                <Button Content="👤  Pacientes" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarPacientesCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Pacientes}" />
                <Button Content="🩺  Novo atendimento" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarNovoAtendimentoCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Atendimento}" />
                <Button Content="📅  Agenda" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarAgendaCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Agenda}" />
                <Button Content="💳  Faturados" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarFaturadosCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Faturados}" />
                <Button Content="🚫  Glosas" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarGlosasCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Glosas}" />
                <Button Content="🧾  Guias TISS" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarTissCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Tiss}" />
                <Button Content="📊  Relatórios" Style="{StaticResource BotaoMenu}"
                        Command="{Binding MostrarRelatoriosCommand}"
                        Background="{Binding SecaoAtual, Converter={StaticResource SecaoSelecionada}, ConverterParameter=Relatorios}" />

                <Border Background="#B91C1C" CornerRadius="8" Margin="0,32,0,0" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔔 Pendências: " Foreground="White" FontWeight="Bold" />
                        <TextBlock Text="{Binding PendenciasBadge}" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Conteúdo -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
