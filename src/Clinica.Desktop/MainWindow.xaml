<Window x:Class="Clinica.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Clinica.Desktop.ViewModels"
        xmlns:views="clr-namespace:Clinica.Desktop.Views"
        xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls"
        Title="Clínica SemDor — Faturamento" Height="740" Width="1280"
        MinHeight="560" MinWidth="960"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Background="{StaticResource Brush.Fundo}">

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NavegarCommand}"
                    CommandParameter="{x:Static vm:Secao.Atendimento}" />
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding AtalhoSalvarCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="P" Command="{Binding AtalhoImprimirCommand}" />
        <KeyBinding Key="F5" Command="{Binding AtalhoAtualizarCommand}" />
        <KeyBinding Modifiers="Ctrl" Key="B" Command="{Binding AlternarMenuCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PacientesViewModel}">
            <views:PacientesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NovoAtendimentoViewModel}">
            <views:NovoAtendimentoView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BaixaViewModel}">
            <views:BaixaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
            <views:RelatoriosView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FaturadosViewModel}">
            <views:FaturadosView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FichaPacienteViewModel}">
            <views:FichaPacienteView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AgendaViewModel}">
            <views:AgendaView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConsultasViewModel}">
            <views:ConsultasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GlosasViewModel}">
            <views:GlosasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TissViewModel}">
            <views:TissView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConsultaGuiasViewModel}">
            <views:ConsultaGuiasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ParametrosViewModel}">
            <views:ParametrosView />
        </DataTemplate>

        <!-- Item da sidebar: barra ativa à esquerda, ícone + rótulo; só ícone quando recolhida -->
        <DataTemplate x:Key="TemplateItemMenu" DataType="{x:Type vm:ItemMenu}">
            <Button Command="{Binding DataContext.NavegarCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Secao}"
                    ToolTip="{Binding Rotulo}"
                    ToolTipService.IsEnabled="{Binding DataContext.MenuRecolhido, RelativeSource={RelativeSource AncestorType=Window}}"
                    Cursor="Hand" Focusable="True" FocusVisualStyle="{x:Null}"
                    Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="fundo" Background="{TemplateBinding Background}"
                                CornerRadius="8" Height="40" Margin="8,2">
                            <Grid>
                                <Border x:Name="barra" Width="3" HorizontalAlignment="Left"
                                        Background="{StaticResource Brush.Acento}" CornerRadius="2"
                                        Margin="0,8" Visibility="Collapsed" />
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock x:Name="icone" Text="{Binding Glifo}"
                                               FontFamily="{StaticResource FonteIcones}" FontSize="16"
                                               Foreground="{StaticResource Brush.Sidebar.Texto}"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="rotulo" Text="{Binding Rotulo}" Margin="12,0,0,0"
                                               FontSize="14" VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.Sidebar.Texto}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="fundo" Property="Background"
                                        Value="{StaticResource Brush.Sidebar.ItemHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="fundo" Property="Background"
                                        Value="{StaticResource Brush.Sidebar.ItemHover}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding EstaAtivo}" Value="True">
                                <Setter TargetName="fundo" Property="Background"
                                        Value="{StaticResource Brush.Sidebar.ItemAtivo}" />
                                <Setter TargetName="barra" Property="Visibility" Value="Visible" />
                                <Setter TargetName="icone" Property="Foreground"
                                        Value="{StaticResource Brush.Sidebar.TextoAtivo}" />
                                <Setter TargetName="rotulo" Property="Foreground"
                                        Value="{StaticResource Brush.Sidebar.TextoAtivo}" />
                                <Setter TargetName="rotulo" Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DataContext.MenuRecolhido, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Value="True">
                                <Setter TargetName="rotulo" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- Grupo (módulo) da sidebar: cabeçalho em legenda maiúscula + itens -->
        <DataTemplate x:Key="TemplateGrupoMenu" DataType="{x:Type vm:GrupoMenu}">
            <StackPanel>
                <TextBlock x:Name="cabecalho" Text="{Binding Nome}" Margin="20,14,12,4"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Texto.Secundario}" />
                <ItemsControl ItemsSource="{Binding Itens}" ItemTemplate="{StaticResource TemplateItemMenu}"
                              Focusable="False" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding DataContext.MenuRecolhido, RelativeSource={RelativeSource AncestorType=Window}}"
                             Value="True">
                    <Setter TargetName="cabecalho" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar recolhível ===== -->
        <Border Grid.Column="0" Width="240"
                Background="{StaticResource Brush.Sidebar.Fundo}"
                BorderBrush="{StaticResource Brush.Borda}" BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MenuRecolhido}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="56"
                                                         Duration="{StaticResource Duracao.Normal}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="240"
                                                         Duration="{StaticResource Duracao.Normal}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <!-- Logo da marca (Clínica SemDor) -->
                <Grid DockPanel.Dock="Top" Margin="14,16,12,10" HorizontalAlignment="Left">
                    <!-- Expandida: logo completa (símbolo + wordmark) -->
                    <Image Source="/Assets/Marca/logo-cor.png" Height="32" HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           ToolTip="Clínica SemDor">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MenuRecolhido}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <!-- Recolhida: só o símbolo -->
                    <Image Source="/Assets/Marca/simbolo-cor.png" Height="30" HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           ToolTip="Clínica SemDor">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MenuRecolhido}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>

                <!-- Versão do app (rodapé; oculta quando recolhida) -->
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding VersaoApp}" Margin="20,0,12,10"
                           FontSize="11" Foreground="{StaticResource Brush.Texto.Secundario}"
                           TextWrapping="Wrap" ToolTip="Versão instalada do sistema">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MenuRecolhido}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Badge de pendências (rodapé; oculto quando recolhida) -->
                <Border DockPanel.Dock="Bottom" Margin="12,8,12,12" CornerRadius="8"
                        Background="{StaticResource Brush.Erro.Suave}" Padding="10,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MenuRecolhido}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PendenciasBadge}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEA8F;" FontFamily="{StaticResource FonteIcones}" FontSize="13"
                                   Foreground="{StaticResource Brush.Erro}" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.Erro}" VerticalAlignment="Center">
                            <Run Text="Pendências: " /><Run Text="{Binding PendenciasBadge, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Módulos -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Grupos}"
                                  ItemTemplate="{StaticResource TemplateGrupoMenu}" Focusable="False"
                                  Margin="0,0,0,8" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== Conteúdo (topbar + breadcrumb + tela) ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Border Grid.Row="0" Height="56" Background="{StaticResource Brush.Superficie}"
                    BorderBrush="{StaticResource Brush.Borda}" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <!-- Hambúrguer -->
                    <Button DockPanel.Dock="Left" Style="{StaticResource BotaoIcone}"
                            Content="&#xE700;" Command="{Binding AlternarMenuCommand}"
                            ToolTip="Recolher/expandir menu (Ctrl+B)"
                            AutomationProperties.Name="Recolher ou expandir o menu" />

                    <!-- Ações à direita -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid>
                            <Button Style="{StaticResource BotaoIcone}" Content="&#xEA8F;"
                                    Command="{Binding NavegarCommand}"
                                    CommandParameter="{x:Static vm:Secao.Pendencias}"
                                    ToolTip="Pendências" AutomationProperties.Name="Notificações de pendências" />
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,4,0,0" IsHitTestVisible="False">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource BadgeContador}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PendenciasBadge}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding PendenciasBadge}" />
                            </Border>
                        </Grid>
                        <Button Style="{StaticResource BotaoIcone}" Content="&#xE713;"
                                Command="{Binding NavegarCommand}"
                                CommandParameter="{x:Static vm:Secao.Parametros}"
                                ToolTip="Configurações" AutomationProperties.Name="Configurações"
                                Margin="4,0,0,0" />
                        <TextBlock Text="&#xE77B;" FontFamily="{StaticResource FonteIcones}" FontSize="16"
                                   Foreground="{StaticResource Brush.Texto.Secundario}"
                                   VerticalAlignment="Center" Margin="12,0,4,0"
                                   ToolTip="Usuário do sistema" />
                    </StackPanel>

                    <!-- Pesquisa global -->
                    <Grid VerticalAlignment="Center" Margin="8,0" HorizontalAlignment="Left" MaxWidth="360">
                        <TextBox x:Name="PesquisaGlobal" Style="{StaticResource CampoPesquisa}"
                                 ctrl:Ajudantes.Placeholder="Pesquisar seção ou paciente…  (Ctrl+F)"
                                 Text="{Binding TextoPesquisaGlobal, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="280">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding NavegarResultadoCommand}" />
                                <KeyBinding Key="Escape" Command="{Binding FecharPesquisaCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Popup IsOpen="{Binding PesquisaAberta}" PlacementTarget="{Binding ElementName=PesquisaGlobal}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                            <Border Background="{StaticResource Brush.Superficie}"
                                    BorderBrush="{StaticResource Brush.Borda}" BorderThickness="1"
                                    CornerRadius="8" Margin="0,4,8,8" Padding="4"
                                    MinWidth="{Binding ActualWidth, ElementName=PesquisaGlobal}">
                                <ItemsControl ItemsSource="{Binding ResultadosPesquisa}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ItemMenu}">
                                            <Button HorizontalContentAlignment="Left" Cursor="Hand"
                                                    Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.NavegarResultadoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Glifo}" FontFamily="{StaticResource FonteIcones}"
                                                                           FontSize="14" Foreground="{StaticResource Brush.Texto.Secundario}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding Grupo}" Margin="10,0,0,0" FontSize="13"
                                                                           Foreground="{StaticResource Brush.Texto.Secundario}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="&#xE76C;" FontFamily="{StaticResource FonteIcones}"
                                                                           FontSize="9" Margin="6,0"
                                                                           Foreground="{StaticResource Brush.Texto.Secundario}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding Rotulo}" FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource Brush.Texto.Primario}"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="b" Property="Background"
                                                                        Value="{StaticResource Brush.Superficie.Hover}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Breadcrumb -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,12,24,0">
                <TextBlock Text="{Binding BreadcrumbModulo}" Style="{StaticResource BreadcrumbAtual}"
                           Foreground="{StaticResource Brush.Texto.Secundario}" FontWeight="Normal" />
                <TextBlock Style="{StaticResource BreadcrumbSeparador}" />
                <TextBlock Text="{Binding BreadcrumbTela}" Style="{StaticResource BreadcrumbAtual}" />
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BreadcrumbDetalhe}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Style="{StaticResource BreadcrumbSeparador}" />
                    <TextBlock Text="{Binding BreadcrumbDetalhe}" Style="{StaticResource BreadcrumbAtual}" />
                </StackPanel>
            </StackPanel>

            <!-- Tela atual -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentViewModel}" />
        </Grid>

        <!-- ===== Snackbar (sobreposto, centro inferior) ===== -->
        <Border Grid.ColumnSpan="2" Style="{StaticResource SnackbarBorda}" Panel.ZIndex="100"
                Visibility="{Binding Snackbar.EstaVisivel, Converter={StaticResource BoolParaVisibilidade}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="{StaticResource FonteIcones}" FontSize="15"
                           VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#xE946;" />
                            <Setter Property="Foreground" Value="White" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Snackbar.Tipo}" Value="Sucesso">
                                    <Setter Property="Text" Value="&#xE73E;" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Snackbar.Sucesso}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Snackbar.Tipo}" Value="Erro">
                                    <Setter Property="Text" Value="&#xE783;" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Snackbar.Erro}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Snackbar.Mensagem}" Foreground="White" FontSize="13"
                           VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="400" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
