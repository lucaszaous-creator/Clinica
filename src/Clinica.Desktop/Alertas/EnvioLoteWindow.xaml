<Window x:Class="Clinica.Desktop.Alertas.EnvioLoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marcar lote como enviado" Width="460" SizeToContent="Height"
        Icon="/Assets/Marca/icone.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" FontFamily="Segoe UI"
        Background="{StaticResource Brush.Fundo}">
    <StackPanel Margin="24">
        <TextBlock x:Name="TxtTitulo" Text="Marcar lote como enviado" Style="{StaticResource H2}" />
        <TextBlock Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,10" TextWrapping="Wrap"
                   Text="Registre quando o lote foi entregue à operadora (portal/webservice) e o protocolo devolvido por ela." />

        <TextBlock Text="Data do envio" Style="{StaticResource Rotulo}" />
        <DatePicker x:Name="DpData" />

        <TextBlock Text="Protocolo da operadora (opcional)" Style="{StaticResource Rotulo}" />
        <TextBox x:Name="TxtProtocolo" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}" Click="Cancelar_Click"
                    IsCancel="True" Margin="0,0,10,0" />
            <Button Content="Marcar enviado" Click="Confirmar_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
