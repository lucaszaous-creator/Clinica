<Window x:Class="Clinica.Desktop.Alertas.RodadaPendenciasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rodar pendências" Height="560" Width="820"
        Icon="/Assets/Marca/icone.png"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI"
        Background="{StaticResource Brush.Fundo}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rodar pendências" Style="{StaticResource DialogoTitulo}" Margin="0,0,0,4" />

        <TextBlock Grid.Row="1" x:Name="TxtResumo" Style="{StaticResource TextoSuave}" Margin="0,0,0,12"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Data da baixa:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{StaticResource Brush.Texto.Primario}" />
            <DatePicker x:Name="DpData" Width="150" />
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="Lista">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="260" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Descricao}" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource Brush.Texto.Primario}" />
                                    <TextBlock Text="{Binding Situacao}" FontSize="12"
                                               Foreground="{StaticResource Brush.Texto.Secundario}" />
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding NumeroGuia, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                         ToolTip="Informe o número da guia para dar baixa" />
                                <TextBox Grid.Column="2" Text="{Binding Justificativa, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center" MaxLength="500" TextWrapping="Wrap" AcceptsReturn="True"
                                         MinHeight="30" VerticalScrollBarVisibility="Auto"
                                         ToolTip="Se não for baixar, justifique como não conformidade" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Style="{StaticResource TextoSuave}"
                       Text="Para cada guia: informe o nº da guia (baixa) OU uma justificativa (não conformidade)." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancelar" Content="Cancelar" Style="{StaticResource BotaoSecundario}"
                        Click="Cancelar_Click" Margin="0,0,8,0" />
                <Button Content="Concluir rodada" Click="Concluir_Click" IsDefault="True" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
