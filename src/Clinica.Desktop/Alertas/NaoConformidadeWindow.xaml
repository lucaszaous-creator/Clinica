<Window x:Class="Clinica.Desktop.Alertas.NaoConformidadeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marcar como não conformidade" Width="480" SizeToContent="Height"
        Icon="/Assets/Marca/icone.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" FontFamily="Segoe UI"
        Background="{StaticResource Brush.Fundo}">
    <StackPanel Margin="24">
        <TextBlock x:Name="TxtTitulo" Text="Marcar como não conformidade" Style="{StaticResource H2}" />
        <TextBlock Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,10" TextWrapping="Wrap"
                   Text="A guia sai das pendências ativas do painel e vai para a aba NC (fica no relatório). Ela volta a ser pendência se for reaberta na aba NC ou quando o paciente retornar. Use quando já se sabe que a guia não será resolvida agora." />

        <TextBlock Text="Justificativa (obrigatória)" Style="{StaticResource Rotulo}" />
        <TextBox x:Name="TxtJustificativa" AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="90" MaxLength="500" VerticalScrollBarVisibility="Auto" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}" Click="Cancelar_Click"
                    IsCancel="True" Margin="0,0,10,0" />
            <Button Content="Marcar não conformidade" Click="Confirmar_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
