<Window x:Class="Clinica.Desktop.Alertas.AvisoPendenciasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Atenção — baixas pendentes" Height="480" Width="720"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        Background="{StaticResource BrushFundo}" ShowInTaskbar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#B91C1C" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔔" FontSize="20" Margin="0,0,10,0" />
                <TextBlock x:Name="TxtResumo" Foreground="White" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Margin="0,0,0,8" Foreground="#334155"
                   Text="Estas guias já podem/precisam ser faturadas e ainda não tiveram baixa. Dê baixa assim que possível para não perder o faturamento." TextWrapping="Wrap" />

        <DataGrid Grid.Row="2" x:Name="Grade" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="14" Height="14"
                                     Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.3*" />
                <DataGridTextColumn Header="Código"
                                    Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="Auto" />
                <DataGridTextColumn Header="Atraso (dias)" Binding="{Binding DiasEmAtraso}" Width="Auto" />
                <DataGridTextColumn Header="Como obter"
                                    Binding="{Binding FormaObtencao, Converter={StaticResource EnumDescricao}}" Width="1.3*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Ver painel de pendências" Click="Fechar_Click" />
        </StackPanel>
    </Grid>
</Window>
