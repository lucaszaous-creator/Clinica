<Window x:Class="Clinica.Desktop.Alertas.AvisoPendenciasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aviso de pendências" Height="480" Width="560"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        Background="White" ShowInTaskbar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Título do modal (design: ícone + 16 semibold) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🔔" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Text="Aviso de pendências" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextoTitulo}" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="TxtResumo" Margin="0,0,0,10" FontSize="13"
                   Foreground="{StaticResource BrushTextoCorpo}" TextWrapping="Wrap" />

        <!-- Linhas âmbar com semáforo, como no ModalAviso do design -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="Lista">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AlertaAviso}" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0"
                                         Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}" />
                                <TextBlock VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap">
                                    <Run Text="{Binding PacienteNome, Mode=OneWay}" FontWeight="Bold" /><Run Text=" — " /><Run Text="{Binding Tipo, Mode=OneWay, Converter={StaticResource EnumDescricao}}" /><Run Text=" · " /><Run Text="{Binding Convenio, Mode=OneWay, Converter={StaticResource EnumDescricao}}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Fechar" Style="{StaticResource BotaoSecundario}" Click="Fechar_Click" Margin="0,0,8,0" />
            <Button Content="Ver painel de pendências" Click="Fechar_Click" />
        </StackPanel>
    </Grid>
</Window>
