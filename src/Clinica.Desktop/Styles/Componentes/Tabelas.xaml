<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Tabelas (DataGrid) — cabeçalho cinza-100 clicável com seta de
         ordenação, linhas alternadas, hover e seleção azul suave.
         ============================================================ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.Borda}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Borda}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource Brush.Superficie}" />
        <Setter Property="RowBackground" Value="{StaticResource Brush.Superficie}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.LinhaAlt}" />
        <Setter Property="RowHeight" Value="36" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Tabela}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="ColumnHeaderHeight" Value="40" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Brush.Superficie.Hover}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Secundario}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Tabela}" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Borda}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter VerticalAlignment="Center" />
                            <TextBlock x:Name="seta" Text="&#xE70E;" FontFamily="{StaticResource FonteIcones}"
                                       FontSize="9" Margin="6,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Acento}" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="seta" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="seta" Property="Visibility" Value="Visible" />
                            <Setter TargetName="seta" Property="Text" Value="&#xE70D;" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.Borda}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Superficie.Hover}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Acento.Suave}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
