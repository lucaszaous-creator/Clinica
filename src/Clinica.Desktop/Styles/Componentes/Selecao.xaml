<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Seleção — CheckBox, RadioButton e Switch (CheckBox com cara
         de interruptor; binda IsChecked igual).
         ============================================================ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid>
                            <Border x:Name="foco" Width="22" Height="22" CornerRadius="6" Margin="-3"
                                    BorderThickness="2" BorderBrush="{StaticResource Brush.Foco}" Opacity="0" />
                            <Border x:Name="box" Width="16" Height="16" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="{StaticResource Brush.Borda.Hover}"
                                    Background="{StaticResource Brush.Superficie}" VerticalAlignment="Center">
                                <Path x:Name="check" Visibility="Collapsed" Stretch="Uniform" Margin="2"
                                      Stroke="White" StrokeThickness="2" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                      Data="M0,5 L4,9 L11,1" />
                            </Border>
                        </Grid>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource Brush.Acento}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Acento}" />
                            <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Acento}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="foco" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid>
                            <Ellipse x:Name="foco" Width="22" Height="22" Margin="-3"
                                     StrokeThickness="2" Stroke="{StaticResource Brush.Foco}" Opacity="0" />
                            <Ellipse x:Name="circulo" Width="16" Height="16" StrokeThickness="1"
                                     Stroke="{StaticResource Brush.Borda.Hover}"
                                     Fill="{StaticResource Brush.Superficie}" VerticalAlignment="Center" />
                            <Ellipse x:Name="ponto" Width="8" Height="8" Fill="{StaticResource Brush.Acento}"
                                     Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="circulo" Property="Stroke" Value="{StaticResource Brush.Acento}" />
                            <Setter TargetName="circulo" Property="StrokeThickness" Value="2" />
                            <Setter TargetName="ponto" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="circulo" Property="Stroke" Value="{StaticResource Brush.Acento}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="foco" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Switch: aplicar a um CheckBox (Style="{StaticResource Switch}") -->
    <Style x:Key="Switch" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid>
                            <Border x:Name="foco" Width="44" Height="26" CornerRadius="13" Margin="-3"
                                    BorderThickness="2" BorderBrush="{StaticResource Brush.Foco}" Opacity="0" />
                            <Border x:Name="trilho" Width="38" Height="20" CornerRadius="10"
                                    Background="{StaticResource Brush.Borda.Hover}" VerticalAlignment="Center">
                                <Ellipse x:Name="bolinha" Width="14" Height="14" Fill="White"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="desloca" X="0" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="trilho" Property="Background" Value="{StaticResource Brush.Acento}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="desloca" Storyboard.TargetProperty="X"
                                                         To="18" Duration="{StaticResource Duracao.Normal}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="desloca" Storyboard.TargetProperty="X"
                                                         To="0" Duration="{StaticResource Duracao.Normal}">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="foco" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
