<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">

    <!-- ============================================================
         Campos de entrada — flat, borda 1px, raio 4, foco azul.
         Placeholder via ctrl:Ajudantes.Placeholder (attached).
         ============================================================ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="{StaticResource Padding.Campo}" />
        <Setter Property="Background" Value="{StaticResource Brush.Superficie}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Borda}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Acento}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Raio.Pequeno}">
                        <Grid>
                            <TextBlock x:Name="placeholder"
                                       Text="{TemplateBinding ctrl:Ajudantes.Placeholder}"
                                       Foreground="{StaticResource Brush.Texto.Secundario}"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Brush.Acento}" />
                            <Setter TargetName="b" Property="BorderThickness" Value="2" />
                            <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Brush.Borda.Hover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.LinhaAlt}" />
                            <Setter Property="Opacity" Value="0.7" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Campo de pesquisa (ícone de lupa à esquerda) -->
    <Style x:Key="CampoPesquisa" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Raio.Pequeno}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;"
                                       FontFamily="{StaticResource FonteIcones}" FontSize="14"
                                       Foreground="{StaticResource Brush.Texto.Secundario}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                            <TextBlock x:Name="placeholder" Grid.Column="1"
                                       Text="{TemplateBinding ctrl:Ajudantes.Placeholder}"
                                       Foreground="{StaticResource Brush.Texto.Secundario}"
                                       Margin="8,0,12,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False" Visibility="Collapsed" />
                            <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1"
                                          Margin="8,8,12,8" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Brush.Acento}" />
                            <Setter TargetName="b" Property="BorderThickness" Value="2" />
                            <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Brush.Borda.Hover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Itens do dropdown do ComboBox -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}"
                            CornerRadius="{StaticResource Raio.Pequeno}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.Superficie.Hover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Brush.Acento.Suave}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox flat -->
    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="Background" Value="{StaticResource Brush.Superficie}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Borda}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="MainBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource Raio.Pequeno}" />
                        <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent">
                                        <TextBlock Text="&#xE70D;" FontFamily="{StaticResource FonteIcones}"
                                                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,10,0" Foreground="{StaticResource Brush.Texto.Secundario}" />
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="10,0,28,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <Popup x:Name="PART_Popup" Placement="Bottom" Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border x:Name="DropDownBorder" Background="{StaticResource Brush.Superficie}"
                                    BorderBrush="{StaticResource Brush.Borda}" BorderThickness="1"
                                    CornerRadius="{StaticResource Raio.Medio}"
                                    MinWidth="{Binding ActualWidth, ElementName=MainBorder}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}" Margin="0,4,8,8" Padding="4">
                                <ScrollViewer>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource Brush.Borda.Hover}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource Brush.Acento}" />
                            <Setter TargetName="MainBorder" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DatePicker (usa o TextBox estilizado internamente) -->
    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{StaticResource Brush.Superficie}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Borda}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Corpo}" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
