<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         CAMADA DE COMPATIBILIDADE (temporária)
         Chaves antigas do Theme.xaml apontando para os valores novos
         do design system azul. Remove-se este arquivo quando todas as
         views migrarem para as chaves Brush.* de Tokens.xaml.
         ============================================================ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Tokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Marca (verde → azul) -->
    <Color x:Key="CorPrimaria">#2563EB</Color>
    <Color x:Key="CorPrimariaHover">#1D4ED8</Color>
    <SolidColorBrush x:Key="BrushPrimaria" Color="{StaticResource Cor.Azul.600}" />
    <SolidColorBrush x:Key="BrushPrimariaHover" Color="{StaticResource Cor.Azul.700}" />
    <!-- BrushVerde100 era o tint de SELEÇÃO (não semântica de sucesso) → azul claro -->
    <SolidColorBrush x:Key="BrushVerde100" Color="{StaticResource Cor.Azul.100}" />
    <SolidColorBrush x:Key="BrushVerdeClaro" Color="{StaticResource Cor.Azul.100}" />

    <!-- Superfícies / neutros -->
    <SolidColorBrush x:Key="BrushFundo" Color="{StaticResource Cor.Cinza.50}" />
    <SolidColorBrush x:Key="BrushCartao" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BrushLinhaAlt" Color="{StaticResource Cor.Cinza.50}" />
    <SolidColorBrush x:Key="BrushBorda" Color="{StaticResource Cor.Cinza.200}" />
    <SolidColorBrush x:Key="BrushBordaHover" Color="{StaticResource Cor.Cinza.300}" />
    <SolidColorBrush x:Key="BrushTextoTitulo" Color="{StaticResource Cor.Cinza.900}" />
    <SolidColorBrush x:Key="BrushTextoCorpo" Color="{StaticResource Cor.Cinza.700}" />
    <SolidColorBrush x:Key="BrushTextoSuave" Color="{StaticResource Cor.Cinza.500}" />

    <!-- Perigo / aviso / sucesso -->
    <SolidColorBrush x:Key="BrushPerigo" Color="{StaticResource Cor.Vermelho.600}" />
    <SolidColorBrush x:Key="BrushPerigoHover" Color="{StaticResource Cor.Vermelho.700}" />
    <SolidColorBrush x:Key="BrushPerigoTexto" Color="{StaticResource Cor.Vermelho.700}" />
    <SolidColorBrush x:Key="BrushPerigoTint" Color="{StaticResource Cor.Vermelho.100}" />
    <SolidColorBrush x:Key="BrushAvisoTint" Color="{StaticResource Cor.Laranja.100}" />
    <SolidColorBrush x:Key="BrushSucessoTint" Color="{StaticResource Cor.Verde.100}" />
    <SolidColorBrush x:Key="BrushSucessoTexto" Color="{StaticResource Cor.Verde.700}" />

    <!-- Semáforo de urgência -->
    <SolidColorBrush x:Key="BrushSemaforoVerde" Color="#2E7D32" />
    <SolidColorBrush x:Key="BrushSemaforoAmarelo" Color="#F9A825" />
    <SolidColorBrush x:Key="BrushSemaforoVermelho" Color="#C62828" />

</ResourceDictionary>
