<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ============================================================
         TOKENS DO DESIGN SYSTEM
         Fonte da verdade visual (espelhada em tokens/*.css e
         docs/design-system/tokens.md). Fluent/Stripe/Linear:
         azul #2563EB, neutros frios, flat, raios discretos.
         ============================================================ -->

    <!-- ============ Cores primitivas ============ -->
    <!-- Azul (marca/acento) -->
    <Color x:Key="Cor.Azul.50">#EFF6FF</Color>
    <Color x:Key="Cor.Azul.100">#DBEAFE</Color>
    <Color x:Key="Cor.Azul.500">#3B82F6</Color>
    <Color x:Key="Cor.Azul.600">#2563EB</Color>
    <Color x:Key="Cor.Azul.700">#1D4ED8</Color>
    <Color x:Key="Cor.Azul.900">#1E3A8A</Color>

    <!-- Cinzas (neutros) -->
    <Color x:Key="Cor.Cinza.50">#F8FAFC</Color>
    <Color x:Key="Cor.Cinza.100">#F1F5F9</Color>
    <Color x:Key="Cor.Cinza.200">#E5E7EB</Color>
    <Color x:Key="Cor.Cinza.300">#D1D5DB</Color>
    <Color x:Key="Cor.Cinza.500">#6B7280</Color>
    <Color x:Key="Cor.Cinza.700">#374151</Color>
    <Color x:Key="Cor.Cinza.900">#111827</Color>

    <!-- Estados -->
    <Color x:Key="Cor.Verde.100">#DCFCE7</Color>
    <Color x:Key="Cor.Verde.600">#16A34A</Color>
    <Color x:Key="Cor.Verde.700">#15803D</Color>
    <Color x:Key="Cor.Laranja.100">#FFEDD5</Color>
    <Color x:Key="Cor.Laranja.600">#EA580C</Color>
    <Color x:Key="Cor.Vermelho.100">#FEE2E2</Color>
    <Color x:Key="Cor.Vermelho.600">#DC2626</Color>
    <Color x:Key="Cor.Vermelho.700">#B91C1C</Color>
    <Color x:Key="Cor.Ciano.100">#E0F2FE</Color>
    <Color x:Key="Cor.Ciano.500">#0EA5E9</Color>

    <!-- ============ Brushes semânticos ============ -->
    <!-- Acento (primária) -->
    <SolidColorBrush x:Key="Brush.Acento" Color="{StaticResource Cor.Azul.600}" />
    <SolidColorBrush x:Key="Brush.Acento.Hover" Color="{StaticResource Cor.Azul.700}" />
    <SolidColorBrush x:Key="Brush.Acento.Suave" Color="{StaticResource Cor.Azul.50}" />
    <SolidColorBrush x:Key="Brush.Acento.Tint" Color="{StaticResource Cor.Azul.100}" />
    <SolidColorBrush x:Key="Brush.Foco" Color="{StaticResource Cor.Azul.500}" />

    <!-- Superfícies -->
    <SolidColorBrush x:Key="Brush.Fundo" Color="{StaticResource Cor.Cinza.50}" />
    <SolidColorBrush x:Key="Brush.Superficie" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Superficie.Hover" Color="{StaticResource Cor.Cinza.100}" />
    <SolidColorBrush x:Key="Brush.LinhaAlt" Color="{StaticResource Cor.Cinza.50}" />
    <SolidColorBrush x:Key="Brush.Borda" Color="{StaticResource Cor.Cinza.200}" />
    <SolidColorBrush x:Key="Brush.Borda.Hover" Color="{StaticResource Cor.Cinza.300}" />

    <!-- Texto -->
    <SolidColorBrush x:Key="Brush.Texto.Primario" Color="{StaticResource Cor.Cinza.900}" />
    <SolidColorBrush x:Key="Brush.Texto.Secundario" Color="{StaticResource Cor.Cinza.500}" />
    <SolidColorBrush x:Key="Brush.Texto.Invertido" Color="#FFFFFF" />

    <!-- Estados semânticos -->
    <SolidColorBrush x:Key="Brush.Sucesso" Color="{StaticResource Cor.Verde.600}" />
    <SolidColorBrush x:Key="Brush.Sucesso.Forte" Color="{StaticResource Cor.Verde.700}" />
    <SolidColorBrush x:Key="Brush.Sucesso.Suave" Color="{StaticResource Cor.Verde.100}" />
    <SolidColorBrush x:Key="Brush.Aviso" Color="{StaticResource Cor.Laranja.600}" />
    <SolidColorBrush x:Key="Brush.Aviso.Suave" Color="{StaticResource Cor.Laranja.100}" />
    <SolidColorBrush x:Key="Brush.Erro" Color="{StaticResource Cor.Vermelho.600}" />
    <SolidColorBrush x:Key="Brush.Erro.Hover" Color="{StaticResource Cor.Vermelho.700}" />
    <SolidColorBrush x:Key="Brush.Erro.Suave" Color="{StaticResource Cor.Vermelho.100}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Cor.Ciano.500}" />
    <SolidColorBrush x:Key="Brush.Info.Suave" Color="{StaticResource Cor.Ciano.100}" />

    <!-- Sidebar clara (estilo Linear) -->
    <SolidColorBrush x:Key="Brush.Sidebar.Fundo" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Sidebar.ItemAtivo" Color="{StaticResource Cor.Azul.50}" />
    <SolidColorBrush x:Key="Brush.Sidebar.ItemHover" Color="{StaticResource Cor.Cinza.100}" />
    <SolidColorBrush x:Key="Brush.Sidebar.Texto" Color="{StaticResource Cor.Cinza.700}" />
    <SolidColorBrush x:Key="Brush.Sidebar.TextoAtivo" Color="{StaticResource Cor.Azul.600}" />

    <!-- Snackbar (fundo escuro exige tons claros dos estados) -->
    <SolidColorBrush x:Key="Brush.Snackbar.Sucesso" Color="#4ADE80" />
    <SolidColorBrush x:Key="Brush.Snackbar.Erro" Color="#F87171" />

    <!-- Semáforo de urgência (mantido do domínio) -->
    <SolidColorBrush x:Key="Brush.Semaforo.Verde" Color="#2E7D32" />
    <SolidColorBrush x:Key="Brush.Semaforo.Amarelo" Color="#F9A825" />
    <SolidColorBrush x:Key="Brush.Semaforo.Vermelho" Color="#C62828" />

    <!-- ============ Tipografia ============ -->
    <sys:Double x:Key="Fonte.H1">24</sys:Double>
    <sys:Double x:Key="Fonte.H2">20</sys:Double>
    <sys:Double x:Key="Fonte.H3">18</sys:Double>
    <sys:Double x:Key="Fonte.Corpo">14</sys:Double>
    <sys:Double x:Key="Fonte.Tabela">13</sys:Double>
    <sys:Double x:Key="Fonte.Legenda">12</sys:Double>

    <!-- ============ Espaçamento (múltiplos de 8; 4 = meia unidade) ============ -->
    <sys:Double x:Key="Espaco.1">4</sys:Double>
    <sys:Double x:Key="Espaco.2">8</sys:Double>
    <sys:Double x:Key="Espaco.3">12</sys:Double>
    <sys:Double x:Key="Espaco.4">16</sys:Double>
    <sys:Double x:Key="Espaco.6">24</sys:Double>
    <sys:Double x:Key="Espaco.8">32</sys:Double>
    <sys:Double x:Key="Espaco.10">40</sys:Double>
    <sys:Double x:Key="Espaco.12">48</sys:Double>
    <sys:Double x:Key="Espaco.16">64</sys:Double>
    <Thickness x:Key="Margem.Pagina">24</Thickness>
    <Thickness x:Key="Padding.Card">16</Thickness>
    <Thickness x:Key="Padding.Campo">12,8</Thickness>
    <Thickness x:Key="Padding.Botao">12,8</Thickness>
    <Thickness x:Key="Padding.BotaoPequeno">8,4</Thickness>

    <!-- ============ Raios ============ -->
    <CornerRadius x:Key="Raio.Pequeno">4</CornerRadius>
    <CornerRadius x:Key="Raio.Medio">8</CornerRadius>
    <CornerRadius x:Key="Raio.Grande">12</CornerRadius>
    <CornerRadius x:Key="Raio.Pilula">999</CornerRadius>

    <!-- ============ Movimento (microinterações ≤150ms) ============ -->
    <Duration x:Key="Duracao.Rapida">0:0:0.10</Duration>
    <Duration x:Key="Duracao.Normal">0:0:0.15</Duration>

    <!-- ============ Iconografia ============ -->
    <FontFamily x:Key="FonteIcones">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

</ResourceDictionary>
