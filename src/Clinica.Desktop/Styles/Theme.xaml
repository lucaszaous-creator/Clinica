<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Estilos base (tipografia e iconografia). Tokens em Tokens.xaml;
         chaves legadas em Compat.xaml; componentes em Componentes/*.
         ============================================================ -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Compat.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="Icone" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FonteIcones}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ============================================================
         Tipografia (escala do DS: 24/20/18/14/13/12)
         ============================================================ -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Fonte.H1}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Fonte.H2}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="Margin" Value="0,8,0,8" />
    </Style>
    <Style x:Key="H3" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Fonte.H3}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Primario}" />
        <Setter Property="Margin" Value="0,8,0,4" />
    </Style>
    <Style x:Key="Rotulo" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Secundario}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Tabela}" />
        <Setter Property="Margin" Value="0,8,0,4" />
    </Style>
    <!-- Texto de apoio (dica sob campos) -->
    <Style x:Key="TextoSuave" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Texto.Secundario}" />
        <Setter Property="FontSize" Value="{StaticResource Fonte.Legenda}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- LEGADO: menu lateral antigo (removido junto com o shell novo) -->
    <Style x:Key="BotaoMenu" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Margin" Value="0,3" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Tag}" FontFamily="{StaticResource FonteIcones}"
                                       FontSize="17" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#22FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
