<UserControl x:Class="Clinica.Desktop.Views.BaixaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <Border Style="{StaticResource Card}" Margin="24" MaxWidth="480" HorizontalAlignment="Left" VerticalAlignment="Top">
        <StackPanel>
            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush.Texto.Primario}" Margin="0,0,0,12">
                <Run Text="Dar baixa — " /><Run Text="{Binding PacienteNome, Mode=OneWay}" />
            </TextBlock>

            <Border Style="{StaticResource AlertaAviso}" Margin="0,0,0,10">
                <TextBlock Text="Confirme a guia no sistema do convênio antes de dar baixa." TextWrapping="Wrap" />
            </Border>

            <Border Style="{StaticResource AlertaInfo}" Margin="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="{Binding Codigo.Tipo, Converter={StaticResource EnumDescricao}}" FontWeight="Bold" />
                    <TextBlock Text="{Binding Codigo.Descricao}" TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AlertaAviso}" Margin="0,0,0,10"
                    Visibility="{Binding TemObservacaoPendencia, Converter={StaticResource BoolParaVisibilidade}}">
                <StackPanel>
                    <TextBlock Text="Por que estava pendente" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding ObservacaoPendencia}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Text="Número da guia gerada (sistema do convênio)" Style="{StaticResource Rotulo}" />
            <TextBox Text="{Binding NumeroGuia, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Data da baixa" Style="{StaticResource Rotulo}" />
            <DatePicker SelectedDate="{Binding DataBaixa}" HorizontalAlignment="Left" Width="160" />

            <TextBlock Text="Observação" Style="{StaticResource Rotulo}" />
            <TextBox Text="{Binding Observacao}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancelar" Command="{Binding CancelarCommand}"
                        Style="{StaticResource BotaoSecundario}" Margin="0,0,8,0" />
                <Button Content="Confirmar baixa" Command="{Binding ConfirmarCommand}"
                        ctrl:Ajudantes.EstaCarregando="{Binding Ocupado}" />
            </StackPanel>
            <TextBlock Text="{Binding Mensagem}" Foreground="{StaticResource Brush.Erro}" Margin="0,10,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
