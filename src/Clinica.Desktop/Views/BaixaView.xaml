<UserControl x:Class="Clinica.Desktop.Views.BaixaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24" MaxWidth="480" HorizontalAlignment="Left">
        <TextBlock Text="Dar baixa na guia" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />

        <Border Background="#F1F5F9" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding PacienteNome}" FontWeight="Bold" FontSize="16" />
                <TextBlock Text="{Binding Codigo.Tipo, Converter={StaticResource EnumDescricao}}" />
                <TextBlock Text="{Binding Codigo.Descricao}" TextWrapping="Wrap" Foreground="#555" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <TextBlock Text="Data da baixa" />
        <DatePicker SelectedDate="{Binding DataBaixa}" Margin="0,2,0,10" />

        <TextBlock Text="Número da guia gerada (sistema do convênio)" />
        <TextBox Text="{Binding NumeroGuia, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

        <TextBlock Text="Observação" />
        <TextBox Text="{Binding Observacao}" Margin="0,2,0,10" Height="60" AcceptsReturn="True" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Confirmar baixa" Command="{Binding ConfirmarCommand}" Padding="16,8" Margin="0,0,10,0" />
            <Button Content="Cancelar" Command="{Binding CancelarCommand}" Padding="16,8" />
        </StackPanel>
        <TextBlock Text="{Binding Mensagem}" Foreground="#B91C1C" Margin="0,10,0,0" />
    </StackPanel>
</UserControl>
