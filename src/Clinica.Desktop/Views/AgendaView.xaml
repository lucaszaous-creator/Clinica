<UserControl x:Class="Clinica.Desktop.Views.AgendaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Novo agendamento (com rolagem própria: o botão "Agendar" nunca fica fora da tela) -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource Card}" Margin="0,0,24,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Novo agendamento" Style="{StaticResource H2}" />

                <TextBlock Text="Buscar paciente (nome ou CPF)" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox ItemsSource="{Binding Pacientes}" SelectedItem="{Binding PacienteSelecionado}"
                         DisplayMemberPath="Nome" Height="120" Margin="0,6,0,4" />

                <TextBlock Text="Data" Style="{StaticResource Rotulo}" />
                <DatePicker SelectedDate="{Binding DataNovo}" />

                <TextBlock Text="Hora (HH:mm)" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Hora}" />

                <TextBlock Text="Modalidade" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Modalidades}" SelectedItem="{Binding Modalidade}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Visibility="{Binding ModalidadeConsulta, Converter={StaticResource BoolParaVisibilidade}}">
                    <TextBlock Text="Especialidade da consulta" Style="{StaticResource Rotulo}" />
                    <ComboBox ItemsSource="{Binding Especialidades}" SelectedItem="{Binding EspecialidadeConsulta}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="Observações" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Observacoes}" Height="48" AcceptsReturn="True" TextWrapping="Wrap" />

                <Button Content="Agendar" Command="{Binding AgendarCommand}" Margin="0,14,0,0"
                        ctrl:Ajudantes.EstaCarregando="{Binding Ocupado}" />
                <TextBlock Text="{Binding Mensagem}" Foreground="{StaticResource Brush.Sucesso.Forte}" Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        </ScrollViewer>

        <!-- Agenda do dia (Card com navegação de dia, como no design) -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Stretch">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="&#xE76B;" Command="{Binding DiaAnteriorCommand}"
                        FontFamily="{StaticResource FonteIcones}"
                        Style="{StaticResource BotaoSecundario}" Padding="8,4" FontSize="11" Width="34" />
                <TextBlock x:Name="TituloAgenda" Grid.Column="1" Text="{Binding TituloDia}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Texto.Primario}" MinWidth="190"
                           TextAlignment="Center" VerticalAlignment="Center" Margin="10,0" />
                <Button Grid.Column="2" Content="&#xE76C;" Command="{Binding ProximoDiaCommand}"
                        FontFamily="{StaticResource FonteIcones}"
                        Style="{StaticResource BotaoSecundario}" Padding="8,4" FontSize="11" Width="34" />
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <CheckBox Content="Semana" IsChecked="{Binding ModoSemana}"
                              Style="{StaticResource Switch}" VerticalAlignment="Center"
                              ToolTip="Alternar entre visão do dia e da semana" Margin="0,0,12,0" />
                    <Button Content="Hoje" Command="{Binding HojeCommand}"
                            Style="{StaticResource BotaoSecundario}" />
                </StackPanel>
            </Grid>

            <DataGrid ItemsSource="{Binding Agendamentos}">
                <DataGrid.Columns>
                    <!-- Colunas de DataGrid ficam fora da árvore visual: binding via x:Reference. -->
                    <DataGridTextColumn Header="Dia" Binding="{Binding DataHora, StringFormat=ddd dd/MM, ConverterCulture=pt-BR}" Width="Auto">
                        <DataGridTextColumn.Visibility>
                            <Binding Path="DataContext.ModoSemana" Converter="{StaticResource BoolParaVisibilidade}"
                                     Source="{x:Reference TituloAgenda}" />
                        </DataGridTextColumn.Visibility>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Hora" Binding="{Binding DataHora, StringFormat=HH:mm}" Width="Auto" />
                    <DataGridTextColumn Header="Paciente" Binding="{Binding Paciente.Nome}" Width="*" />
                    <DataGridTextColumn Header="Procedimento"
                                        Binding="{Binding ModalidadePrevista, Converter={StaticResource EnumDescricao}}" Width="1.4*" />
                    <DataGridTextColumn Header="Situação" Binding="{Binding Status}" Width="Auto" />
                    <DataGridTextColumn Header="Obs." Binding="{Binding Observacoes}" Width="1.4*" />
                    <DataGridTemplateColumn Header="" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource BotaoAcaoGridSecundario}" Margin="0,0,6,0"
                                            ToolTip="Enviar confirmação por WhatsApp"
                                            AutomationProperties.Name="Enviar confirmação por WhatsApp"
                                            Command="{Binding DataContext.WhatsappCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE8BD;" FontFamily="{StaticResource FonteIcones}" FontSize="13" />
                                    </Button>
                                    <Button Content="Iniciar atendimento"
                                            Style="{StaticResource BotaoAcaoGridSecundario}"
                                            Command="{Binding DataContext.ConfirmarPresencaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Faltou" Margin="6,0,0,0"
                                            Style="{StaticResource BotaoAcaoGridSecundario}"
                                            Command="{Binding DataContext.FaltouCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Cancelar" Margin="6,0,0,0"
                                            Style="{StaticResource BotaoAcaoGridPerigo}"
                                            Command="{Binding DataContext.CancelarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
        </Border>
    </Grid>
</UserControl>
