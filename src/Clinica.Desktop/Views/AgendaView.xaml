<UserControl x:Class="Clinica.Desktop.Views.AgendaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Novo agendamento -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,24,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Novo agendamento" Style="{StaticResource H2}" />

                <TextBlock Text="Buscar paciente (nome ou CPF)" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox ItemsSource="{Binding Pacientes}" SelectedItem="{Binding PacienteSelecionado}"
                         DisplayMemberPath="Nome" Height="120" Margin="0,6,0,4" />

                <TextBlock Text="Data" Style="{StaticResource Rotulo}" />
                <DatePicker SelectedDate="{Binding DataNovo}" />

                <TextBlock Text="Hora (HH:mm)" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Hora}" />

                <TextBlock Text="Modalidade" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Modalidades}" SelectedItem="{Binding Modalidade}" />

                <TextBlock Text="Observações" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Observacoes}" Height="48" AcceptsReturn="True" TextWrapping="Wrap" />

                <Button Content="Agendar" Command="{Binding AgendarCommand}" Margin="0,14,0,0" />
                <TextBlock Text="{Binding Mensagem}" Foreground="#14532D" Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Agenda do dia (Card com navegação de dia, como no design) -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Stretch">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="‹" Command="{Binding DiaAnteriorCommand}"
                        Style="{StaticResource BotaoSecundario}" Padding="8,3" FontSize="12" Width="34" />
                <TextBlock Grid.Column="1" Text="{Binding TituloDia}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextoTitulo}" MinWidth="190"
                           TextAlignment="Center" VerticalAlignment="Center" Margin="10,0" />
                <Button Grid.Column="2" Content="›" Command="{Binding ProximoDiaCommand}"
                        Style="{StaticResource BotaoSecundario}" Padding="8,3" FontSize="12" Width="34" />
                <Button Grid.Column="4" Content="Hoje" Command="{Binding HojeCommand}"
                        Style="{StaticResource BotaoSecundario}" />
            </Grid>

            <DataGrid ItemsSource="{Binding Agendamentos}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Hora" Binding="{Binding DataHora, StringFormat=HH:mm}" Width="Auto" />
                    <DataGridTextColumn Header="Paciente" Binding="{Binding Paciente.Nome}" Width="*" />
                    <DataGridTextColumn Header="Procedimento"
                                        Binding="{Binding ModalidadePrevista, Converter={StaticResource EnumDescricao}}" Width="1.4*" />
                    <DataGridTextColumn Header="Situação" Binding="{Binding Status}" Width="Auto" />
                    <DataGridTextColumn Header="Obs." Binding="{Binding Observacoes}" Width="1.4*" />
                    <DataGridTemplateColumn Header="" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Iniciar atendimento" Padding="8,3" FontSize="12"
                                            Style="{StaticResource BotaoSecundario}"
                                            Command="{Binding DataContext.ConfirmarPresencaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Faltou" Padding="8,3" FontSize="12" Margin="6,0,0,0"
                                            Style="{StaticResource BotaoSecundario}"
                                            Command="{Binding DataContext.FaltouCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Cancelar" Padding="8,3" FontSize="12" Margin="6,0,0,0"
                                            Style="{StaticResource BotaoPerigo}"
                                            Command="{Binding DataContext.CancelarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
        </Border>
    </Grid>
</UserControl>
