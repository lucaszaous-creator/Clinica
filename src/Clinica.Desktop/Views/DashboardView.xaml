<UserControl x:Class="Clinica.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <!-- Rolagem vertical: em telas baixas (notebooks) nada fica cortado/inacessível. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <DockPanel Margin="0,0,0,14">
                <TextBlock Text="Pendências de faturamento" Style="{StaticResource H1}" Margin="0" />
                <Button Command="{Binding AtualizarCommand}"
                        HorizontalAlignment="Right" Style="{StaticResource BotaoSecundario}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                        <TextBlock Text="Atualizar" />
                    </StackPanel>
                </Button>
            </DockPanel>
            <Border Style="{StaticResource AlertaPerigo}" Margin="0,0,0,14"
                    Visibility="{Binding TemPendencias, Converter={StaticResource BoolParaVisibilidade}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xEA8F;" Style="{StaticResource Icone}" FontSize="19"
                               VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White" />
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" FontSize="15" FontWeight="Bold" Foreground="White">
                        <Run Text="Existem " /><Run Text="{Binding TotalCodigos, Mode=OneWay}" /><Run Text=" guias pendentes de baixa. Dê baixa assim que possível para não perder o faturamento." />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- KPIs do painel -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14">
            <Border Style="{StaticResource CardKpi}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Guias em aberto" Style="{StaticResource CardKpi.Rotulo}" />
                    <TextBlock Text="{Binding TotalCodigos}" Style="{StaticResource CardKpi.Valor}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Urgentes (vermelho)" Style="{StaticResource CardKpi.Rotulo}" />
                    <TextBlock Text="{Binding CodigosUrgentes}" Style="{StaticResource CardKpi.Valor}"
                               Foreground="{StaticResource Brush.Erro}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Consultas a renovar" Style="{StaticResource CardKpi.Rotulo}" />
                    <TextBlock Text="{Binding ConsultasARenovar}" Style="{StaticResource CardKpi.Valor}"
                               Foreground="{StaticResource Brush.Aviso}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Background="{StaticResource Brush.Acento}"
                    BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="Pendências totais" Style="{StaticResource CardKpi.Rotulo}"
                               Foreground="{StaticResource Brush.Acento.Tint}" />
                    <TextBlock Text="{Binding Total}" Style="{StaticResource CardKpi.Valor}" Foreground="White" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Convênio:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Width="200" ItemsSource="{Binding OpcoesConvenio}" SelectedItem="{Binding FiltroConvenio}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Urgência:" VerticalAlignment="Center" Margin="16,0,6,0" />
            <ComboBox Width="140" ItemsSource="{Binding OpcoesUrgencia}" SelectedItem="{Binding FiltroUrgencia}" />
        </StackPanel>
        <Button Grid.Column="1" Style="{StaticResource BotaoSecundario}"
                ToolTip="Dar baixa em várias guias de uma vez (selecione as linhas com Ctrl/Shift + clique)"
                Command="{Binding DarBaixaEmLoteCommand}"
                CommandParameter="{Binding SelectedItems, ElementName=GridPendencias}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE9D5;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                <TextBlock Text="Baixa em lote" />
            </StackPanel>
        </Button>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource Card}">
        <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Guias e códigos pendentes" Style="{StaticResource H2}" Margin="0,0,0,8" />
        <Grid>
        <ctrl:EmptyState Glifo="&#xE930;" Titulo="Nenhuma pendência" Panel.ZIndex="1"
                         Descricao="Tudo em dia por aqui. Use Atualizar (F5) para recarregar.">
            <ctrl:EmptyState.Style>
                <Style TargetType="ctrl:EmptyState" BasedOn="{StaticResource {x:Type ctrl:EmptyState}}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Codigos.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ctrl:EmptyState.Style>
        </ctrl:EmptyState>
        <DataGrid x:Name="GridPendencias" ItemsSource="{Binding Codigos}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False" SelectionMode="Extended" MaxHeight="380" MinHeight="120">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="16" Height="16"
                                     Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.4*" />
                <DataGridTextColumn Header="Código"
                                    Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="0.7*" />
                <DataGridTextColumn Header="Prevista" Binding="{Binding DataPrevista}" Width="0.9*" />
                <DataGridTextColumn Header="Atraso (dias)" Binding="{Binding DiasEmAtraso}" Width="0.9*" />
                <DataGridTextColumn Header="Como obter"
                                    Binding="{Binding FormaObtencao, Converter={StaticResource EnumDescricao}}" Width="1.4*" />
                <DataGridTemplateColumn Header="" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Dar baixa" Style="{StaticResource BotaoAcaoGrid}"
                                    Command="{Binding DataContext.DarBaixaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Grid>
        </DockPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,16,0,0"
                Visibility="{Binding TemRecursos, Converter={StaticResource BoolParaVisibilidade}}">
        <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Glosas — prazo de recurso correndo" Style="{StaticResource H2}" Margin="0,0,0,8" />
        <DataGrid ItemsSource="{Binding Recursos}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False" MaxHeight="180">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="16" Height="16"
                                     Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.2*" />
                <DataGridTextColumn Header="Nº guia" Binding="{Binding NumeroGuia}" Width="Auto" />
                <DataGridTextColumn Header="Motivo" Binding="{Binding MotivoResumo}" Width="1.4*" />
                <DataGridTextColumn Header="Prazo até" Binding="{Binding DataLimiteRecurso}" Width="Auto" />
                <DataGridTextColumn Header="Dias restantes" Binding="{Binding DiasParaFimPrazo}" Width="Auto" />
                <DataGridTemplateColumn Header="" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Abrir glosas" Style="{StaticResource BotaoAcaoGridSecundario}"
                                    ToolTip="Ir para o Controle de glosas para reapresentar/recorrer"
                                    Command="{Binding DataContext.AbrirGlosasCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,16,0,0"
                Visibility="{Binding TemCarteirinhas, Converter={StaticResource BoolParaVisibilidade}}">
        <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Carteirinhas vencidas ou vencendo (30 dias)" Style="{StaticResource H2}" Margin="0,0,0,8" />
        <DataGrid ItemsSource="{Binding Carteirinhas}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False" MaxHeight="180">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="16" Height="16"
                                     Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.2*" />
                <DataGridTextColumn Header="Carteirinha" Binding="{Binding Carteirinha}" Width="*" />
                <DataGridTextColumn Header="Validade" Binding="{Binding Validade}" Width="Auto" />
                <DataGridTextColumn Header="Dias p/ vencer" Binding="{Binding DiasParaVencer}" Width="Auto" />
                <DataGridTemplateColumn Header="" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Abrir ficha" Style="{StaticResource BotaoAcaoGridSecundario}"
                                    ToolTip="Abrir a ficha do paciente para atualizar a carteirinha"
                                    Command="{Binding DataContext.AbrirFichaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>
        </Border>

        <Border Grid.Row="6" Style="{StaticResource Card}" Margin="0,16,0,0">
        <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Consultas a renovar" Style="{StaticResource H2}" Margin="0,0,0,8" />
        <DataGrid ItemsSource="{Binding Consultas}" AutoGenerateColumns="False"
                  IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False" MaxHeight="180">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="16" Height="16"
                                     Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Paciente" Binding="{Binding PacienteNome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.4*" />
                <DataGridTextColumn Header="Vence em" Binding="{Binding DataVencimento}" Width="*" />
                <DataGridTextColumn Header="Dias p/ vencer" Binding="{Binding DiasParaVencer}" Width="*" />
                <DataGridTemplateColumn Header="" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Renovar" Style="{StaticResource BotaoAcaoGrid}"
                                    ToolTip="Gerar/renovar a consulta deste paciente para hoje"
                                    Command="{Binding DataContext.RenovarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
