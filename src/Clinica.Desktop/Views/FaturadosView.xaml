<UserControl x:Class="Clinica.Desktop.Views.FaturadosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Guias faturadas (baixadas)" Style="{StaticResource H1}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <DatePicker SelectedDate="{Binding Inicio}" Width="140" />
            <TextBlock Text="Até:" VerticalAlignment="Center" Margin="16,0,6,0" />
            <DatePicker SelectedDate="{Binding Fim}" Width="140" />
            <Button Content="Buscar" Command="{Binding BuscarCommand}" Margin="16,0,0,0" />
            <Button Command="{Binding ExportarCsvCommand}" Style="{StaticResource BotaoSecundario}" Margin="8,0,0,0"
                    ToolTip="Exportar as guias do período em CSV (abre no Excel)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                    <TextBlock Text="Exportar CSV" />
                </StackPanel>
            </Button>
            <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{StaticResource Brush.Texto.Secundario}" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}">
        <DataGrid ItemsSource="{Binding Baixados}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Paciente" Binding="{Binding Atendimento.Paciente.Nome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Atendimento.Paciente.Convenio, Converter={StaticResource EnumDescricao}}" Width="*" />
                <DataGridTextColumn Header="Código"
                                    Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="Auto" />
                <DataGridTextColumn Header="Nº guia" Binding="{Binding NumeroGuiaReal}" Width="*" />
                <DataGridTextColumn Header="Baixa" Binding="{Binding DataBaixa}" Width="Auto" />
                <DataGridTextColumn Header="Glosa" Binding="{Binding Glosa}" Width="Auto" />
                <DataGridTemplateColumn Header="Ações" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Capa"
                                        Style="{StaticResource BotaoAcaoGridSecundario}"
                                        ToolTip="Reimprimir a capa de faturamento deste atendimento"
                                        Command="{Binding DataContext.CapaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Guia" Margin="6,0,0,0"
                                        Style="{StaticResource BotaoAcaoGridSecundario}"
                                        ToolTip="Imprimir a guia deste atendimento no leiaute padrão ANS (PDF)"
                                        Command="{Binding DataContext.GuiaPdfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Glosar" Margin="6,0,0,0"
                                        Style="{StaticResource BotaoAcaoGridSecundario}"
                                        Command="{Binding DataContext.GlosarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Estornar" Margin="6,0,0,0"
                                        Style="{StaticResource BotaoAcaoGridPerigo}"
                                        Command="{Binding DataContext.EstornarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Border>
    </Grid>
</UserControl>
