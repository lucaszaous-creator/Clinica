<UserControl x:Class="Clinica.Desktop.Views.FichaPacienteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button Content="← Voltar" Command="{Binding FecharFichaCommand}" Style="{StaticResource BotaoSecundario}" />
            <TextBlock Text="Ficha do paciente" Style="{StaticResource H1}" Margin="16,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <!-- Dados -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding Paciente.Nome}" FontSize="18" FontWeight="Bold" />
                <WrapPanel Margin="0,6,0,0">
                    <TextBlock Text="CPF: " Foreground="#64748B" />
                    <TextBlock Text="{Binding CpfFormatado}" Margin="0,0,20,0" />
                    <TextBlock Text="Convênio: " Foreground="#64748B" />
                    <TextBlock Text="{Binding Paciente.Convenio, Converter={StaticResource EnumDescricao}}" Margin="0,0,20,0" />
                    <TextBlock Text="Telefone: " Foreground="#64748B" />
                    <TextBlock Text="{Binding Paciente.Telefone}" Margin="0,0,20,0" />
                    <TextBlock Text="Categoria: " Foreground="#64748B" />
                    <TextBlock Text="{Binding Paciente.Categoria}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}">
        <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Histórico de códigos" Style="{StaticResource H2}" Margin="0,0,0,8" />
        <DataGrid ItemsSource="{Binding Codigos}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding Atendimento.Data}" Width="Auto" />
                <DataGridTextColumn Header="Código"
                                    Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="Auto" />
                <DataGridTextColumn Header="Situação"
                                    Binding="{Binding Path=., Converter={StaticResource StatusCodigo}}" Width="2*" />
                <DataGridTemplateColumn Header="Ação" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Estornar"
                                    Style="{StaticResource BotaoAcaoGridPerigo}"
                                    Visibility="{Binding Baixado, Converter={StaticResource BoolParaVisibilidade}}"
                                    Command="{Binding DataContext.EstornarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>
        </Border>
    </Grid>
</UserControl>
