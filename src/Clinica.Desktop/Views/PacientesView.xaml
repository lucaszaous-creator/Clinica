<UserControl x:Class="Clinica.Desktop.Views.PacientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Formulário -->
        <StackPanel Grid.Column="0" Margin="0,0,24,0">
            <TextBlock Text="Novo paciente" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

            <TextBlock Text="Nome" />
            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

            <TextBlock Text="Documento" />
            <TextBox Text="{Binding Documento}" Margin="0,2,0,10" />

            <TextBlock Text="Telefone" />
            <TextBox Text="{Binding Telefone}" Margin="0,2,0,10" />

            <TextBlock Text="Convênio" />
            <ComboBox ItemsSource="{Binding Convenios}" SelectedItem="{Binding Convenio}" Margin="0,2,0,10" />

            <TextBlock Text="Sexo (usado pela Petrobras)" />
            <ComboBox ItemsSource="{Binding Sexos}" SelectedItem="{Binding Sexo}" Margin="0,2,0,10" />

            <CheckBox Content="Possui app da Unimed (gera QR Code)" IsChecked="{Binding PossuiApp}" Margin="0,4,0,12" />

            <Button Content="Salvar paciente" Command="{Binding SalvarCommand}" Padding="12,8" />
            <TextBlock Text="{Binding Mensagem}" Foreground="#14532D" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Lista -->
        <DockPanel Grid.Column="1">
            <TextBlock Text="Pacientes cadastrados" FontSize="20" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,12" />
            <DataGrid ItemsSource="{Binding Pacientes}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" />
                    <DataGridTextColumn Header="Convênio"
                                        Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.4*" />
                    <DataGridCheckBoxColumn Header="App" Binding="{Binding PossuiApp}" Width="0.5*" />
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="0.8*" />
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
