<UserControl x:Class="Clinica.Desktop.Views.PacientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Formulário -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,24,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{Binding TituloFormulario}" Style="{StaticResource H2}" />

                <TextBlock Text="Nome" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="CPF" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Telefone" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Telefone}" />

                <TextBlock Text="Convênio" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Convenios}" SelectedValue="{Binding ConvenioCodigo}"
                          SelectedValuePath="Codigo" DisplayMemberPath="Nome" />

                <TextBlock Text="Sexo (usado pela Petrobras)" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Sexos}" SelectedItem="{Binding Sexo}" />

                <CheckBox Content="Possui app da Unimed (gera QR Code)" IsChecked="{Binding PossuiApp}" Margin="0,12,0,12" />

                <TextBlock Text="Categoria (semáforo)" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Categorias}" SelectedItem="{Binding Categoria}" />
                <TextBlock Text="Sugerida pelo convênio + app; pode ser ajustada manualmente."
                           FontSize="11" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,3,0,0" TextWrapping="Wrap" />

                <TextBlock Text="Modalidade padrão" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Modalidades}" SelectedItem="{Binding ModalidadePreferida}" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Salvar" Command="{Binding SalvarCommand}"
                            ctrl:Ajudantes.EstaCarregando="{Binding Ocupado}" />
                    <Button Content="Limpar" Style="{StaticResource BotaoSecundario}" Command="{Binding NovoCommand}" Margin="8,0,0,0" />
                </StackPanel>
                <TextBlock Text="{Binding Mensagem}" Foreground="{StaticResource Brush.Sucesso.Forte}" Margin="0,10,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Lista -->
        <DockPanel Grid.Column="1">
            <TextBlock Text="Pacientes" Style="{StaticResource H1}" DockPanel.Dock="Top" />

            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="Buscar paciente (nome ou CPF)" Style="{StaticResource Rotulo}" Margin="0,0,0,3" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CampoPesquisa}"
                             ctrl:Ajudantes.Placeholder="Digite o nome ou CPF para buscar…" />
                    <Button Grid.Column="1" Command="{Binding BuscarCommand}"
                            Style="{StaticResource BotaoSecundario}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                            <TextBlock Text="Atualizar" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <DataGrid ItemsSource="{Binding Pacientes}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" />
                    <DataGridTextColumn Header="CPF" Binding="{Binding Documento, Converter={StaticResource Cpf}}" Width="Auto" />
                    <DataGridTextColumn Header="Convênio"
                                        Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="1.3*" />
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="Auto" />
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="Auto" />
                    <DataGridTemplateColumn Header="Ações" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Ficha" Style="{StaticResource BotaoAcaoGrid}"
                                            Command="{Binding DataContext.AbrirFichaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Editar" Margin="6,0,0,0"
                                            Style="{StaticResource BotaoAcaoGridSecundario}"
                                            Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Excluir" Margin="6,0,0,0"
                                            Style="{StaticResource BotaoAcaoGridPerigo}"
                                            Command="{Binding DataContext.ExcluirCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
