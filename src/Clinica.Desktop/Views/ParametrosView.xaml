<UserControl x:Class="Clinica.Desktop.Views.ParametrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Parâmetros dos convênios" Style="{StaticResource H1}" />
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,12"
                   Text="Ajuste os números das regras sem recompilar. 'Validade da consulta' é a renovação (ex.: 22/30 dias). 'Dias até o 2º código' é o intervalo do 2º código (padrão 1 = 24h). Deixe a validade vazia para convênios sem consulta renovável." />

        <DataGrid Grid.Row="2" ItemsSource="{Binding Itens}" IsReadOnly="False" CanUserAddRows="False"
                  AutoGenerateColumns="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Convênio" IsReadOnly="True"
                                    Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="2*" />
                <DataGridTextColumn Header="Validade da consulta (dias)"
                                    Binding="{Binding ValidadeConsultaDias}" Width="*" />
                <DataGridTextColumn Header="Dias até o 2º código"
                                    Binding="{Binding DiasSegundoCodigo}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Salvar parâmetros" Command="{Binding SalvarCommand}" />
            <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#14532D" />
        </StackPanel>
    </Grid>
</UserControl>
