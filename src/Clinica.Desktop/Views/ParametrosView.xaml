<UserControl x:Class="Clinica.Desktop.Views.ParametrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Clinica.Desktop.ViewModels"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configurações" Style="{StaticResource H1}" />

        <TabControl Grid.Row="1">
            <!-- ===== Convênios ===== -->
            <TabItem Header="Convênios">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Gerencie os convênios atendidos e ajuste os números das regras. 'Novo convênio' cria uma variante que reutiliza a REGRA de faturamento de uma família existente (ex.: um plano que fatura como a Unimed Padrão), com nome próprio. Selecione um convênio na lista para editá-lo — lembre de clicar em 'Salvar configurações' ao terminar." />

                    <!-- Catálogo de convênios (nome, família, ativo) -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,0,0,12">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Convênios atendidos" Style="{StaticResource H2}" Margin="0" />
                                <Button Content="+ Novo convênio" Command="{Binding NovoConvenioCommand}"
                                        Style="{StaticResource BotaoSecundario}" HorizontalAlignment="Right" />
                            </Grid>
                            <DataGrid x:Name="GridCatalogo" ItemsSource="{Binding Catalogo}" SelectedItem="{Binding ConvenioSelecionado}"
                                      IsReadOnly="False" CanUserAddRows="False" MaxHeight="320"
                                      AutoGenerateColumns="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                    <!-- Template em vez de ComboBoxColumn para travar a família dos embutidos (a regra deles vive no código) -->
                                    <DataGridTemplateColumn Header="Fatura como (família)" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{x:Static vm:FontesEnum.Familias}"
                                                          SelectedItem="{Binding Familia, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding FamiliaEditavel}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Configuração de faturamento do convênio selecionado (aplica-se aos 'Personalizado') -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,0,0,12"
                            DataContext="{Binding ConvenioSelecionado}"
                            Visibility="{Binding DataContext.TemConvenioSelecionado, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolParaVisibilidade}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center">
                                    <Run Text="Faturamento de " /><Run Text="{Binding Nome, Mode=OneWay}" FontWeight="Bold" />
                                </TextBlock>
                                <Button Content="Excluir convênio" Style="{StaticResource BotaoPerigo}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Command="{Binding DataContext.RemoverConvenioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Visibility="{Binding PodeExcluir, Converter={StaticResource BoolParaVisibilidade}}" />
                            </Grid>
                            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextoSuave}">
                                        <Setter Property="Text" Value="Convênio que fatura pela regra fixa da família escolhida. Troque a família para 'Personalizado' se quiser configurar a regra manualmente." />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EhEmbutido}" Value="True">
                                                <Setter Property="Text" Value="Convênio embutido: a regra de faturamento é fixa no sistema. Você pode renomeá-lo ou desativá-lo, mas não trocar a família nem excluí-lo." />
                                            </DataTrigger>
                                            <!-- Depois do embutido de propósito: o 'Personalizado' embutido também mostra os ajustes -->
                                            <DataTrigger Binding="{Binding EhPersonalizado}" Value="True">
                                                <Setter Property="Text" Value="Convênio personalizado: os ajustes abaixo definem como o faturamento é gerado." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Nome do convênio" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Fatura como (família)" Style="{StaticResource Rotulo}" />
                                    <ComboBox ItemsSource="{x:Static vm:FontesEnum.Familias}" SelectedItem="{Binding Familia}"
                                              IsEnabled="{Binding FamiliaEditavel}" />
                                </StackPanel>
                            </Grid>

                            <!-- Ajustes da regra genérica — só fazem sentido quando a família é Personalizado -->
                            <StackPanel Visibility="{Binding EhPersonalizado, Converter={StaticResource BoolParaVisibilidade}}">
                                <CheckBox Content="Realiza eletroacupuntura (candidata a 2º código)" IsChecked="{Binding FazEletro}" Margin="0,8,0,4" />
                                <CheckBox Content="Gera 2º código (+dias) nas modalidades duplas" IsChecked="{Binding TemSegundoCodigo}" Margin="0,4" />
                                <CheckBox Content="2º código só é possível se o paciente tiver app" IsChecked="{Binding SegundoCodigoDependeApp}" Margin="0,4" />
                                <CheckBox Content="Fatura BSV" IsChecked="{Binding FaturaBsv}" Margin="0,4" />
                                <CheckBox Content="Exige inverter as datas no sistema (BSV)" IsChecked="{Binding InverteDatasBsv}" Margin="0,4" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Como obter o 2º código" Style="{StaticResource Rotulo}" />
                                        <ComboBox ItemsSource="{x:Static vm:FontesEnum.FormasObtencao}" SelectedItem="{Binding FormaSegundoCodigo}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                        <TextBlock Text="Dias até o 2º código" Style="{StaticResource Rotulo}" />
                                        <TextBox Text="{Binding DiasSegundoCodigo}" ctrl:Ajudantes.SomenteNumeros="True" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                        <TextBlock Text="Validade da consulta (dias, vazio = sem)" Style="{StaticResource Rotulo}" />
                                        <TextBox Text="{Binding ValidadeConsultaDias, TargetNullValue=''}" ctrl:Ajudantes.SomenteNumeros="True" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Categoria (com app)" Style="{StaticResource Rotulo}" />
                                        <ComboBox ItemsSource="{x:Static vm:FontesEnum.Categorias}" SelectedItem="{Binding CategoriaComApp}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Categoria (sem app)" Style="{StaticResource Rotulo}" />
                                        <ComboBox ItemsSource="{x:Static vm:FontesEnum.Categorias}" SelectedItem="{Binding CategoriaSemApp}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Parâmetros numéricos por família -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Regras por família de convênio" Style="{StaticResource H2}" Margin="0,0,0,8" />
                            <DataGrid x:Name="GridFamilias" ItemsSource="{Binding Itens}" IsReadOnly="False" CanUserAddRows="False"
                                      MaxHeight="320" AutoGenerateColumns="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Família" IsReadOnly="True"
                                                        Binding="{Binding Convenio}" Width="2*" />
                                    <DataGridTextColumn Header="Validade da consulta (dias)"
                                                        Binding="{Binding ValidadeConsultaDias}" Width="*" />
                                    <DataGridTextColumn Header="Dias até o 2º código"
                                                        Binding="{Binding DiasSegundoCodigo}" Width="*" />
                                    <DataGridComboBoxColumn Header="Categoria (com app)"
                                                            SelectedItemBinding="{Binding CategoriaComApp}"
                                                            ItemsSource="{x:Static vm:FontesEnum.Categorias}" Width="*" />
                                    <DataGridComboBoxColumn Header="Categoria (sem app)"
                                                            SelectedItemBinding="{Binding CategoriaSemApp}"
                                                            ItemsSource="{x:Static vm:FontesEnum.Categorias}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Alerta de consultas a vencer (configuração global, vale em todas as máquinas) -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Alerta de consultas a vencer" Style="{StaticResource H2}" Margin="0,0,0,4" />
                            <TextBlock Style="{StaticResource TextoSuave}" Margin="0,0,0,10"
                                       Text="Configuração global (vale em todas as máquinas). As consultas dentro desta janela antes do vencimento passam a aparecer em alerta." />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Avisar com" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                                <TextBox Text="{Binding JanelaAlertaConsultaDias}"
                                         ctrl:Ajudantes.SomenteNumeros="True"
                                         MinWidth="64" MaxLength="4" Padding="10,6" TextAlignment="Center"
                                         VerticalContentAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="dias de antecedência" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Prazo de recurso de glosa" Style="{StaticResource H2}" Margin="0,0,0,4" />
                            <TextBlock Style="{StaticResource TextoSuave}" Margin="0,0,0,10"
                                       Text="Configuração global. Ao registrar uma glosa, o sistema calcula a data-limite do recurso com este prazo e acompanha no painel de pendências." />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Recorrer em até" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                                <TextBox Text="{Binding PrazoRecursoGlosaDias}"
                                         ctrl:Ajudantes.SomenteNumeros="True"
                                         MinWidth="64" MaxLength="4" Padding="10,6" TextAlignment="Center"
                                         VerticalContentAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="dias após a glosa" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Rodar as pendências" Style="{StaticResource H2}" Margin="0,0,0,4" />
                            <TextBlock Style="{StaticResource TextoSuave}" Margin="0,0,0,10"
                                       Text="Fechamento de ciclo (como rodar as diárias): ao vencer o prazo, o sistema cobra uma decisão em cada guia pendente — dar baixa ou justificar como não conformidade (que sai do painel e vai para o relatório)." />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Rodar a cada" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                                <TextBox Text="{Binding IntervaloRodadaPendenciasDias}"
                                         ctrl:Ajudantes.SomenteNumeros="True"
                                         MinWidth="64" MaxLength="4" Padding="10,6" TextAlignment="Center"
                                         VerticalContentAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="dias" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                            </StackPanel>
                            <TextBlock Text="Além das guias, cobrar também na rodada:" Margin="0,12,0,6"
                                       Foreground="{StaticResource Brush.Texto.Primario}" />
                            <CheckBox Content="Consultas a renovar" IsChecked="{Binding RodadaAplicaConsultas}"
                                      Foreground="{StaticResource Brush.Texto.Primario}" Margin="0,0,0,4" />
                            <CheckBox Content="Carteirinhas a vencer" IsChecked="{Binding RodadaAplicaCarteirinhas}"
                                      Foreground="{StaticResource Brush.Texto.Primario}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Modalidades ===== -->
            <TabItem Header="Modalidades">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Modalidades de atendimento oferecidas (o que é realizado na visita). 'Nova modalidade' cria uma variante com nome próprio que reutiliza o COMPORTAMENTO de uma modalidade embutida (ex.: 'Auriculoterapia' que fatura como 'Acupuntura (apenas)'). Desative para ocultar dos lançamentos sem apagar o histórico." />

                    <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Modalidades de atendimento" Style="{StaticResource H2}" Margin="0" />
                                <Button Content="+ Nova modalidade" Command="{Binding NovaModalidadeCommand}"
                                        Style="{StaticResource BotaoSecundario}" HorizontalAlignment="Right" />
                            </Grid>
                            <DataGrid x:Name="GridModalidades" ItemsSource="{Binding Modalidades}"
                                      IsReadOnly="False" CanUserAddRows="False" MaxHeight="360"
                                      AutoGenerateColumns="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                    <!-- Template para travar a base das modalidades embutidas (o comportamento delas vive no código) -->
                                    <DataGridTemplateColumn Header="Comporta-se como" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{x:Static vm:FontesEnum.ModalidadesBase}"
                                                          SelectedItem="{Binding Base, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding BaseEditavel}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Excluir" Style="{StaticResource BotaoAcaoGridPerigo}"
                                                        Command="{Binding DataContext.RemoverModalidadeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding PodeExcluir, Converter={StaticResource BoolParaVisibilidade}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    <TextBlock Style="{StaticResource TextoSuave}" Margin="0,10,0,0" TextWrapping="Wrap"
                               Text="As modalidades embutidas não podem ser excluídas nem trocar de comportamento — apenas renomeadas ou desativadas. Lembre de clicar em 'Salvar configurações' ao terminar." />
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Especialidades ===== -->
            <TabItem Header="Especialidades">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Especialidades das consultas avulsas (discriminam a consulta nos relatórios por especialidade). Adicione as que a clínica atende. Desative para ocultar sem apagar o histórico." />

                    <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Especialidades de consulta" Style="{StaticResource H2}" Margin="0" />
                                <Button Content="+ Nova especialidade" Command="{Binding NovaEspecialidadeCommand}"
                                        Style="{StaticResource BotaoSecundario}" HorizontalAlignment="Right" />
                            </Grid>
                            <DataGrid x:Name="GridEspecialidades" ItemsSource="{Binding Especialidades}"
                                      IsReadOnly="False" CanUserAddRows="False" MaxHeight="360"
                                      AutoGenerateColumns="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Excluir" Style="{StaticResource BotaoAcaoGridPerigo}"
                                                        Command="{Binding DataContext.RemoverEspecialidadeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding PodeExcluir, Converter={StaticResource BoolParaVisibilidade}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    <TextBlock Style="{StaticResource TextoSuave}" Margin="0,10,0,0" TextWrapping="Wrap"
                               Text="As especialidades embutidas (usadas na rotação da Petrobras) não podem ser excluídas — apenas renomeadas ou desativadas. Lembre de clicar em 'Salvar configurações' ao terminar." />
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Clínica / prestador ===== -->
            <TabItem Header="Clínica / prestador">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Identificação da clínica impressa na capa de faturamento e usada no lote TISS. Vale para todas as máquinas." />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Razão social" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding RazaoSocial}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Nome fantasia (exibido na capa)" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding NomeFantasia}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="CNPJ" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Cnpj}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="CNES" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Cnes}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                    <TextBlock Text="Endereço (rua, nº, bairro, cidade/UF, CEP)" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Endereco}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Telefone" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Telefone}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="E-mail" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Email}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Código do prestador na operadora" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding CodigoNaOperadora}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Registro ANS da operadora" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding RegistroAnsOperadora}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Códigos TUSS ===== -->
            <TabItem Header="Códigos TUSS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Código TUSS de cada procedimento, usado no lote TISS. Pode variar conforme a operadora." />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Acupuntura" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussAcupuntura}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Eletroacupuntura" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussEletro}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="BSV" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussBsv}" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Consulta" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussConsulta}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                    <TextBlock Text="Consulta especialidade" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussEspecialidade}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
            <Button Content="Salvar configurações" Command="{Binding SalvarCommand}"
                    Click="Salvar_Click"
                    ctrl:Ajudantes.EstaCarregando="{Binding Salvando}" />
            <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center" Margin="16,0,0,0"
                       TextWrapping="Wrap" MaxWidth="640">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Sucesso.Forte}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MensagemEhErro}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Erro}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
