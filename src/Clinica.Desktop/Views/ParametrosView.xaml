<UserControl x:Class="Clinica.Desktop.Views.ParametrosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Clinica.Desktop.ViewModels">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configurações" Style="{StaticResource H1}" />

        <TabControl Grid.Row="1">
            <!-- ===== Convênios ===== -->
            <TabItem Header="Convênios">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Gerencie os convênios atendidos e ajuste os números das regras. 'Novo convênio' cria uma variante que reutiliza a REGRA de faturamento de uma família existente (ex.: um plano que fatura como a Unimed Padrão), com nome próprio." />

                    <!-- Catálogo de convênios (nome, família, ativo) -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,0,0,12">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="Convênios atendidos" Style="{StaticResource H2}" Margin="0" />
                                <Button Content="+ Novo convênio" Command="{Binding NovoConvenioCommand}"
                                        Style="{StaticResource BotaoSecundario}" HorizontalAlignment="Right" />
                            </Grid>
                            <DataGrid ItemsSource="{Binding Catalogo}" SelectedItem="{Binding ConvenioSelecionado}"
                                      IsReadOnly="False" CanUserAddRows="False"
                                      AutoGenerateColumns="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*" />
                                    <DataGridComboBoxColumn Header="Fatura como (família)"
                                                            SelectedItemBinding="{Binding Familia}"
                                                            ItemsSource="{x:Static vm:FontesEnum.Familias}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Configuração de faturamento do convênio selecionado (aplica-se aos 'Personalizado') -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,0,0,12"
                            DataContext="{Binding ConvenioSelecionado}"
                            Visibility="{Binding DataContext.TemConvenioSelecionado, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolParaVisibilidade}}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource H2}" Margin="0,0,0,4">
                                <Run Text="Faturamento de " /><Run Text="{Binding Text, ElementName=NomeConvenioBox}" FontWeight="Bold" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource TextoSuave}" Margin="0,0,0,10"
                                       Text="Estes ajustes valem quando o convênio 'fatura como' Personalizado. Para os 4 embutidos, as regras são fixas." />

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Nome do convênio" Style="{StaticResource Rotulo}" />
                                    <TextBox x:Name="NomeConvenioBox" Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Fatura como (família)" Style="{StaticResource Rotulo}" />
                                    <ComboBox ItemsSource="{x:Static vm:FontesEnum.Familias}" SelectedItem="{Binding Familia}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Realiza eletroacupuntura (candidata a 2º código)" IsChecked="{Binding FazEletro}" Margin="0,8,0,4" />
                            <CheckBox Content="Gera 2º código (+dias) nas modalidades duplas" IsChecked="{Binding TemSegundoCodigo}" Margin="0,4" />
                            <CheckBox Content="2º código só é possível se o paciente tiver app" IsChecked="{Binding SegundoCodigoDependeApp}" Margin="0,4" />
                            <CheckBox Content="Fatura BSV" IsChecked="{Binding FaturaBsv}" Margin="0,4" />
                            <CheckBox Content="Exige inverter as datas no sistema (BSV)" IsChecked="{Binding InverteDatasBsv}" Margin="0,4" />

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Como obter o 2º código" Style="{StaticResource Rotulo}" />
                                    <ComboBox ItemsSource="{x:Static vm:FontesEnum.FormasObtencao}" SelectedItem="{Binding FormaSegundoCodigo}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                    <TextBlock Text="Dias até o 2º código" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding DiasSegundoCodigo}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="Validade da consulta (dias, vazio = sem)" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding ValidadeConsultaDias}" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Categoria (com app)" Style="{StaticResource Rotulo}" />
                                    <ComboBox ItemsSource="{x:Static vm:FontesEnum.Categorias}" SelectedItem="{Binding CategoriaComApp}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Categoria (sem app)" Style="{StaticResource Rotulo}" />
                                    <ComboBox ItemsSource="{x:Static vm:FontesEnum.Categorias}" SelectedItem="{Binding CategoriaSemApp}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Parâmetros numéricos por família -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Regras por família de convênio" Style="{StaticResource H2}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding Itens}" IsReadOnly="False" CanUserAddRows="False"
                                      AutoGenerateColumns="False" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Família" IsReadOnly="True"
                                                        Binding="{Binding Convenio}" Width="2*" />
                                    <DataGridTextColumn Header="Validade da consulta (dias)"
                                                        Binding="{Binding ValidadeConsultaDias}" Width="*" />
                                    <DataGridTextColumn Header="Dias até o 2º código"
                                                        Binding="{Binding DiasSegundoCodigo}" Width="*" />
                                    <DataGridComboBoxColumn Header="Categoria (com app)"
                                                            SelectedItemBinding="{Binding CategoriaComApp}"
                                                            ItemsSource="{x:Static vm:FontesEnum.Categorias}" Width="*" />
                                    <DataGridComboBoxColumn Header="Categoria (sem app)"
                                                            SelectedItemBinding="{Binding CategoriaSemApp}"
                                                            ItemsSource="{x:Static vm:FontesEnum.Categorias}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Alerta de consultas a vencer (configuração global, vale em todas as máquinas) -->
                    <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Alerta de consultas a vencer" Style="{StaticResource H2}" Margin="0,0,0,4" />
                            <TextBlock Style="{StaticResource TextoSuave}" Margin="0,0,0,10"
                                       Text="Configuração global (vale em todas as máquinas). As consultas dentro desta janela antes do vencimento passam a aparecer em alerta." />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Avisar com" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                                <TextBox Text="{Binding JanelaAlertaConsultaDias}"
                                         MinWidth="64" MaxLength="4" Padding="10,6" TextAlignment="Center"
                                         VerticalContentAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock Text="dias de antecedência" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource Brush.Texto.Primario}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Clínica / prestador ===== -->
            <TabItem Header="Clínica / prestador">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Identificação da clínica impressa na capa de faturamento e usada no lote TISS. Vale para todas as máquinas." />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Razão social" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding RazaoSocial}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Nome fantasia (exibido na capa)" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding NomeFantasia}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="CNPJ" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Cnpj}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="CNES" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Cnes}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                    <TextBlock Text="Endereço (rua, nº, bairro, cidade/UF, CEP)" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Endereco}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Telefone" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Telefone}" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="E-mail" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding Email}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Código do prestador na operadora" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding CodigoNaOperadora}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Registro ANS da operadora" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding RegistroAnsOperadora}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Códigos TUSS ===== -->
            <TabItem Header="Códigos TUSS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="860" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                               Text="Código TUSS de cada procedimento, usado no lote TISS. Pode variar conforme a operadora." />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Acupuntura" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussAcupuntura}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                    <TextBlock Text="Eletroacupuntura" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussEletro}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="BSV" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussBsv}" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Consulta" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussConsulta}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                    <TextBlock Text="Consulta especialidade" Style="{StaticResource Rotulo}" />
                                    <TextBox Text="{Binding TussEspecialidade}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0" VerticalAlignment="Center">
            <Button Content="Salvar configurações" Command="{Binding SalvarCommand}" />
            <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{StaticResource Brush.Sucesso.Forte}" />
        </StackPanel>
    </Grid>
</UserControl>
