<UserControl x:Class="Clinica.Desktop.Views.TissView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Guias TISS — lotes" Style="{StaticResource H1}" />
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                   Text="Gere o lote (XML padrão TISS 4.01) com as guias baixadas ainda não exportadas, marque o envio à operadora (protocolo) e registre o retorno do demonstrativo — glosas entram no Controle de glosas com prazo de recurso. Dados do prestador e códigos TUSS ficam em Configurações." />

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Novo lote (guias baixadas do período, ainda sem lote)" Style="{StaticResource H2}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <DatePicker SelectedDate="{Binding Inicio}" Width="140" />
                    <TextBlock Text="Até:" VerticalAlignment="Center" Margin="16,0,6,0" />
                    <DatePicker SelectedDate="{Binding Fim}" Width="140" />
                    <Button Content="Gerar lote TISS (.xml)" Command="{Binding ExportarCommand}" Margin="16,0,0,0"
                            ctrl:Ajudantes.EstaCarregando="{Binding Ocupado}" />
                </StackPanel>
                <TextBlock Text="{Binding Mensagem}" Foreground="{StaticResource Brush.Sucesso.Forte}" Margin="0,10,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Lotes gerados" Style="{StaticResource H2}" Margin="0,0,0,8" />
                <Grid>
                    <ctrl:EmptyState Glifo="&#xE8F1;" Titulo="Nenhum lote ainda" Panel.ZIndex="1"
                                     Descricao="Os lotes exportados aparecem aqui com o histórico de envio e retorno.">
                        <ctrl:EmptyState.Style>
                            <Style TargetType="ctrl:EmptyState" BasedOn="{StaticResource {x:Type ctrl:EmptyState}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Lotes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ctrl:EmptyState.Style>
                    </ctrl:EmptyState>
                    <DataGrid ItemsSource="{Binding Lotes}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nº lote" Binding="{Binding Numero}" Width="Auto" />
                            <DataGridTextColumn Header="Gerado em" Binding="{Binding DataGeracao}" Width="Auto" />
                            <DataGridTextColumn Header="Guias" Binding="{Binding Guias}" Width="Auto" />
                            <DataGridTextColumn Header="Situação" Binding="{Binding StatusRotulo}" Width="Auto" />
                            <DataGridTextColumn Header="Enviado em" Binding="{Binding DataEnvio}" Width="Auto" />
                            <DataGridTextColumn Header="Protocolo" Binding="{Binding Protocolo}" Width="*" />
                            <DataGridTextColumn Header="Retorno em" Binding="{Binding DataRetorno}" Width="Auto" />
                            <DataGridTextColumn Header="Glosadas" Binding="{Binding Glosadas}" Width="Auto" />
                            <DataGridTemplateColumn Header="Ações" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="XML" Style="{StaticResource BotaoAcaoGridSecundario}"
                                                    ToolTip="Baixar novamente o XML deste lote (2ª via)"
                                                    Command="{Binding DataContext.BaixarXmlCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Marcar enviado" Margin="6,0,0,0"
                                                    Style="{StaticResource BotaoAcaoGrid}"
                                                    Visibility="{Binding PodeMarcarEnviado, Converter={StaticResource BoolParaVisibilidade}}"
                                                    Command="{Binding DataContext.MarcarEnviadoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Registrar retorno" Margin="6,0,0,0"
                                                    Style="{StaticResource BotaoAcaoGrid}"
                                                    Visibility="{Binding PodeRegistrarRetorno, Converter={StaticResource BoolParaVisibilidade}}"
                                                    Command="{Binding DataContext.RegistrarRetornoCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
