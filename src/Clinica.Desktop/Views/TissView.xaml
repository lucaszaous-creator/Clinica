<UserControl x:Class="Clinica.Desktop.Views.TissView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
            <TextBlock Text="Guias TISS" Style="{StaticResource H1}" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.Texto.Secundario}" Margin="0,0,0,12"
                       Text="Gera o lote de guias no formato TISS (XML) a partir das guias já faturadas. Os dados do prestador e os códigos TUSS ficam na tela Configurações." />

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Exportar lote (período)" Style="{StaticResource H2}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker SelectedDate="{Binding Inicio}" Width="140" />
                        <TextBlock Text="Até:" VerticalAlignment="Center" Margin="16,0,6,0" />
                        <DatePicker SelectedDate="{Binding Fim}" Width="140" />
                        <Button Content="Exportar guias TISS (.xml)" Command="{Binding ExportarCommand}" Margin="16,0,0,0"
                                ctrl:Ajudantes.EstaCarregando="{Binding Ocupado}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Mensagem}" Foreground="{StaticResource Brush.Sucesso.Forte}" Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
