<UserControl x:Class="Clinica.Desktop.Views.TissView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="820" HorizontalAlignment="Left">
            <TextBlock Text="Guias TISS" Style="{StaticResource H1}" />
            <TextBlock TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,12"
                       Text="Gera o lote de guias no formato TISS (XML) a partir das guias já faturadas. Configure os dados do prestador e os códigos TUSS de cada procedimento — pode ser necessário ajustar conforme a operadora." />

            <!-- Config do prestador -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Dados do prestador" Style="{StaticResource H2}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Razão social" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding RazaoSocial}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="CNPJ" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding Cnpj}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Código do prestador na operadora" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding CodigoNaOperadora}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Registro ANS da operadora" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding RegistroAnsOperadora}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Códigos TUSS por procedimento" Style="{StaticResource H2}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Acupuntura" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding TussAcupuntura}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,6,0">
                            <TextBlock Text="Eletroacupuntura" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding TussEletro}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0,0,0">
                            <TextBlock Text="BSV" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding TussBsv}" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Consulta" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding TussConsulta}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,6,0">
                            <TextBlock Text="Consulta especialidade" Style="{StaticResource Rotulo}" />
                            <TextBox Text="{Binding TussEspecialidade}" />
                        </StackPanel>
                    </Grid>

                    <Button Content="Salvar configuração" Command="{Binding SalvarConfigCommand}"
                            HorizontalAlignment="Left" Margin="0,14,0,0" />
                </StackPanel>
            </Border>

            <!-- Exportação -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Exportar lote (período)" Style="{StaticResource H2}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker SelectedDate="{Binding Inicio}" Width="140" />
                        <TextBlock Text="Até:" VerticalAlignment="Center" Margin="16,0,6,0" />
                        <DatePicker SelectedDate="{Binding Fim}" Width="140" />
                        <Button Content="Exportar guias TISS (.xml)" Command="{Binding ExportarCommand}" Margin="16,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding Mensagem}" Foreground="#14532D" Margin="0,10,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
