<UserControl x:Class="Clinica.Desktop.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Relatórios de faturamento" Style="{StaticResource H1}" />

        <!-- Filtro de período -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
            <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <DatePicker SelectedDate="{Binding Inicio}" Width="140" />
            <TextBlock Text="Até:" VerticalAlignment="Center" Margin="16,0,6,0" />
            <DatePicker SelectedDate="{Binding Fim}" Width="140" />
            <Button Content="Gerar" Command="{Binding GerarCommand}" Padding="20,6" Margin="16,0,0,0" />
        </StackPanel>

        <!-- KPIs -->
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
            <Border Background="#F1F5F9" CornerRadius="10" Padding="16" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Códigos gerados" Foreground="#555" />
                    <TextBlock Text="{Binding Resumo.TotalCodigos, FallbackValue=0}" FontSize="30" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Background="#DCFCE7" CornerRadius="10" Padding="16" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Baixados" Foreground="#166534" />
                    <TextBlock Text="{Binding Resumo.Baixados, FallbackValue=0}" FontSize="30" FontWeight="Bold" Foreground="#166534" />
                </StackPanel>
            </Border>
            <Border Background="#FEE2E2" CornerRadius="10" Padding="16" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Pendentes" Foreground="#991B1B" />
                    <TextBlock Text="{Binding Resumo.Pendentes, FallbackValue=0}" FontSize="30" FontWeight="Bold" Foreground="#991B1B" />
                </StackPanel>
            </Border>
            <Border Background="#14532D" CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="Taxa de baixa" Foreground="#A7F3D0" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Resumo.TaxaBaixa, FallbackValue=0}" FontSize="30" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="%" FontSize="20" Foreground="White" VerticalAlignment="Bottom" Margin="2,0,0,4" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" VerticalAlignment="Top">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Faturamento por convênio (período)"
                               Style="{StaticResource H2}" Margin="0,0,0,8" />
                    <DataGrid ItemsSource="{Binding PorConvenio}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Convênio"
                                                Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="2*" />
                            <DataGridTextColumn Header="Gerados" Binding="{Binding TotalCodigos}" Width="*" />
                            <DataGridTextColumn Header="Baixados" Binding="{Binding Baixados}" Width="*" />
                            <DataGridTextColumn Header="Pendentes" Binding="{Binding Pendentes}" Width="*" />
                            <DataGridTextColumn Header="% baixa" Binding="{Binding TaxaBaixa}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Pendências em aberto (envelhecimento)"
                               Style="{StaticResource H2}" Margin="0,0,0,8" TextWrapping="Wrap" />
                    <DataGrid ItemsSource="{Binding Envelhecimento}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Faixa" Binding="{Binding Faixa}" Width="*" />
                            <DataGridTextColumn Header="Qtde" Binding="{Binding Quantidade}" Width="Auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
