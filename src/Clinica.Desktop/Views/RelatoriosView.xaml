<UserControl x:Class="Clinica.Desktop.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:Clinica.Desktop.Controls">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Relatórios de faturamento" Style="{StaticResource H1}" />

        <!-- Filtro de período -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
            <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <DatePicker SelectedDate="{Binding Inicio}" Width="140" />
            <TextBlock Text="Até:" VerticalAlignment="Center" Margin="16,0,6,0" />
            <DatePicker SelectedDate="{Binding Fim}" Width="140" />
            <Button Content="Gerar" Command="{Binding GerarCommand}" Padding="20,6" Margin="16,0,0,0" />
            <Button Style="{StaticResource BotaoSecundario}" Command="{Binding ExportarCsvCommand}"
                    ToolTip="Exportar as tabelas deste relatório em CSV (abre no Excel)" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                    <TextBlock Text="Exportar CSV" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource BotaoSecundario}" Command="{Binding GerarFechamentoCommand}"
                    ctrl:Ajudantes.EstaCarregando="{Binding GerandoFechamento}"
                    ToolTip="PDF de fechamento do período: pendências vencidas nominais, glosas em aberto e evolução mensal"
                    Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE749;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                    <TextBlock Text="Fechamento (PDF)" />
                </StackPanel>
            </Button>
            <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{StaticResource Brush.Erro}" />
        </StackPanel>

        <!-- KPIs -->
        <UniformGrid Grid.Row="2" Columns="6" Margin="0,0,0,20">
            <Border Style="{StaticResource CardKpi}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Códigos gerados" Style="{StaticResource CardKpi.Rotulo}" />
                    <TextBlock Text="{Binding Resumo.TotalCodigos, FallbackValue=0}" Style="{StaticResource CardKpi.Valor}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Background="{StaticResource Brush.Sucesso.Suave}"
                    BorderThickness="0" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Baixados" Style="{StaticResource CardKpi.Rotulo}"
                               Foreground="{StaticResource Brush.Sucesso.Forte}" />
                    <TextBlock Text="{Binding Resumo.Baixados, FallbackValue=0}" Style="{StaticResource CardKpi.Valor}"
                               Foreground="{StaticResource Brush.Sucesso.Forte}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Background="{StaticResource Brush.Erro.Suave}"
                    BorderThickness="0" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Pendentes" Style="{StaticResource CardKpi.Rotulo}"
                               Foreground="{StaticResource Brush.Erro}" />
                    <TextBlock Text="{Binding Resumo.Pendentes, FallbackValue=0}" Style="{StaticResource CardKpi.Valor}"
                               Foreground="{StaticResource Brush.Erro}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Background="{StaticResource Brush.Acento}" BorderThickness="0" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Taxa de baixa" Style="{StaticResource CardKpi.Rotulo}"
                               Foreground="{StaticResource Brush.Acento.Tint}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Resumo.TaxaBaixa, FallbackValue=0}" Style="{StaticResource CardKpi.Valor}"
                                   Foreground="White" />
                        <TextBlock Text="%" FontSize="18" Foreground="White" VerticalAlignment="Bottom" Margin="2,0,0,4" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}" Background="{StaticResource Brush.Aviso.Suave}"
                    BorderThickness="0" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Taxa de glosa" Style="{StaticResource CardKpi.Rotulo}"
                               Foreground="{StaticResource Brush.Aviso}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Resumo.TaxaGlosa, FallbackValue=0}" Style="{StaticResource CardKpi.Valor}"
                                   Foreground="{StaticResource Brush.Aviso}" />
                        <TextBlock Text="%" FontSize="18" Foreground="{StaticResource Brush.Aviso}"
                                   VerticalAlignment="Bottom" Margin="2,0,0,4" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardKpi}">
                <StackPanel>
                    <TextBlock Text="Tempo médio de baixa" Style="{StaticResource CardKpi.Rotulo}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Resumo.TempoMedioBaixaDias, FallbackValue='—', TargetNullValue='—'}"
                                   Style="{StaticResource CardKpi.Valor}" />
                        <TextBlock Text="dias" FontSize="14" Foreground="{StaticResource Brush.Texto.Secundario}"
                                   VerticalAlignment="Bottom" Margin="4,0,0,6" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Faturamento por convênio (período)"
                               Style="{StaticResource H2}" Margin="0,0,0,8" />
                    <DataGrid ItemsSource="{Binding PorConvenio}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Convênio"
                                                Binding="{Binding Convenio, Converter={StaticResource EnumDescricao}}" Width="2*" />
                            <DataGridTextColumn Header="Gerados" Binding="{Binding TotalCodigos}" Width="*" />
                            <DataGridTextColumn Header="Baixados" Binding="{Binding Baixados}" Width="*" />
                            <DataGridTextColumn Header="Pendentes" Binding="{Binding Pendentes}" Width="*" />
                            <DataGridTextColumn Header="% baixa" Binding="{Binding TaxaBaixa}" Width="*" />
                            <DataGridTextColumn Header="Glosadas" Binding="{Binding Glosadas}" Width="*" />
                            <DataGridTextColumn Header="% glosa" Binding="{Binding TaxaGlosa}" Width="*" />
                            <DataGridTextColumn Header="Baixa média (d)" Binding="{Binding TempoMedioBaixaDias, TargetNullValue='—'}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,16,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Consultas por especialidade (período)"
                               Style="{StaticResource H2}" Margin="0,0,0,8" />
                    <StackPanel>
                        <DataGrid ItemsSource="{Binding ConsultasEspecialidades}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Especialidade" Binding="{Binding Especialidade}" Width="2*" />
                                <DataGridTextColumn Header="Consultas" Binding="{Binding Quantidade}" Width="*" />
                                <DataGridTextColumn Header="Baixadas" Binding="{Binding Baixadas}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Nenhuma consulta avulsa lançada no período." Margin="0,6,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextoSuave}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConsultasEspecialidades.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Pendências em aberto (envelhecimento)"
                                   Style="{StaticResource H2}" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <DataGrid ItemsSource="{Binding Envelhecimento}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Faixa" Binding="{Binding Faixa}" Width="*" />
                                <DataGridTextColumn Header="Qtde" Binding="{Binding Quantidade}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource Card}" VerticalAlignment="Top" Margin="0,16,0,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Evolução mensal (últimos 6 meses)"
                                   Style="{StaticResource H2}" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <DataGrid ItemsSource="{Binding Comparativo}" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mês" Binding="{Binding Rotulo}" Width="*" />
                                <DataGridTextColumn Header="Gerados" Binding="{Binding TotalCodigos}" Width="Auto" />
                                <DataGridTextColumn Header="Baixados" Binding="{Binding Baixados}" Width="Auto" />
                                <DataGridTextColumn Header="% baixa" Binding="{Binding TaxaBaixa}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
