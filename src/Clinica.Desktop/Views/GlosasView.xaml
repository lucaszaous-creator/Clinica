<UserControl x:Class="Clinica.Desktop.Views.GlosasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Controle de glosas" Style="{StaticResource H1}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox Content="Mostrar só glosas em aberto" IsChecked="{Binding SomenteEmAberto}" VerticalAlignment="Center" />
            <Button Command="{Binding BuscarCommand}" Style="{StaticResource BotaoSecundario}" Margin="16,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                    <TextBlock Text="Atualizar" />
                </StackPanel>
            </Button>
            <Button Command="{Binding GerarRecursoXmlCommand}" Style="{StaticResource BotaoSecundario}" Margin="8,0,0,0"
                    ToolTip="Gerar o XML de recurso de glosa (padrão TISS) com as glosas em aberto da lista">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8A7;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                    <TextBlock Text="Recurso de glosa (.xml)" />
                </StackPanel>
            </Button>
            <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center" Margin="16,0,0,0"
                       Foreground="{StaticResource Brush.Erro}" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}">
        <DataGrid ItemsSource="{Binding Glosas}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="16" Height="16"
                                     Fill="{Binding Urgencia, Converter={StaticResource UrgenciaParaCor}}"
                                     ToolTip="Urgência do prazo de recurso" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Paciente" Binding="{Binding Codigo.Atendimento.Paciente.Nome}" Width="*" />
                <DataGridTextColumn Header="Convênio"
                                    Binding="{Binding Codigo.Atendimento.Paciente.Convenio, Converter={StaticResource EnumDescricao}}" Width="1.1*" />
                <DataGridTextColumn Header="Código"
                                    Binding="{Binding Codigo.Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                <DataGridTextColumn Header="Nº guia" Binding="{Binding Codigo.NumeroGuiaReal}" Width="Auto" />
                <DataGridTextColumn Header="Glosada em" Binding="{Binding Codigo.DataGlosa}" Width="Auto" />
                <DataGridTextColumn Header="Motivo (ANS)" Binding="{Binding MotivoAns}" Width="1.4*" />
                <DataGridTextColumn Header="Complemento" Binding="{Binding Codigo.MotivoGlosa}" Width="1.2*" />
                <DataGridTextColumn Header="Prazo recurso" Binding="{Binding PrazoRotulo}" Width="Auto" />
                <DataGridTextColumn Header="Situação" Binding="{Binding Codigo.Glosa}" Width="Auto" />
                <DataGridTemplateColumn Header="Ações" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Reapresentar" Style="{StaticResource BotaoAcaoGrid}"
                                        Command="{Binding DataContext.ReapresentarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Recuperada" Margin="6,0,0,0"
                                        Style="{StaticResource BotaoAcaoGridSecundario}"
                                        Command="{Binding DataContext.RecuperarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        </Border>
    </Grid>
</UserControl>
