<UserControl x:Class="Clinica.Desktop.Views.NovoAtendimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,24,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Novo atendimento" Style="{StaticResource H2}" />

                <TextBlock Text="Buscar paciente (nome ou CPF)" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox ItemsSource="{Binding Pacientes}" SelectedItem="{Binding PacienteSelecionado}"
                         DisplayMemberPath="Nome" Height="130" Margin="0,6,0,4" />
                <TextBlock Text="{Binding PacienteSelecionado.Nome, StringFormat='Selecionado: {0}'}"
                           Foreground="#14532D" FontWeight="SemiBold" Margin="0,0,0,8" />

                <TextBlock Text="Data" Style="{StaticResource Rotulo}" />
                <DatePicker SelectedDate="{Binding Data}" />

                <TextBlock Text="Modalidade" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Modalidades}" SelectedItem="{Binding Modalidade}" />

                <StackPanel Visibility="{Binding ModalidadeDupla, Converter={StaticResource BoolParaVisibilidade}}">
                    <TextBlock Text="Qual código o convênio libera primeiro (hoje)?" Style="{StaticResource Rotulo}" />
                    <ComboBox ItemsSource="{Binding OpcoesPrimeiroCodigo}" SelectedItem="{Binding PrimeiroCodigo}" />
                    <TextBlock Text="O outro código vira o 2º (previsto para +24h)."
                               FontSize="11" Foreground="#64748B" Margin="0,3,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Text="Observações" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Observacoes}" AcceptsReturn="True" Height="56" TextWrapping="Wrap" />

                <Button Content="Lançar e gerar códigos" Command="{Binding LancarCommand}" Margin="0,14,0,0" />

                <Border Background="#DCFCE7" CornerRadius="8" Padding="12,10" Margin="0,12,0,0"
                        Visibility="{Binding Lancado, Converter={StaticResource BoolParaVisibilidade}}">
                    <StackPanel>
                        <TextBlock Text="{Binding NumeroAtendimento, StringFormat='Atendimento nº {0}'}"
                                   FontWeight="Bold" Foreground="#166534" />
                        <Button Command="{Binding GerarCapaCommand}"
                                Style="{StaticResource BotaoSecundario}" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE749;" Style="{StaticResource Icone}" FontSize="13" Margin="0,0,6,0" />
                                <TextBlock Text="Gerar capa inicial (PDF)" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1">
            <!-- Regras por convênio (card informativo do design) -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Regras por convênio" Style="{StaticResource H2}" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BrushTextoCorpo}" FontSize="13" LineHeight="22">
                        <Run Text="• Unimed Padrão: código no app ou por ligação." /><LineBreak />
                        <Run Text="• Unimed Intercâmbio: " /><Run Text="2 códigos" FontWeight="Bold" /><Run Text=" — o 2º deve ser obtido em +24h por ligação." /><LineBreak />
                        <Run Text="• Amil: guia gerada no portal; baixa após atendimento." /><LineBreak />
                        <Run Text="• Petrobras: exige sexo do paciente no cadastro." />
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Códigos gerados" Style="{StaticResource H2}" Margin="0,0,0,8" />
                    <DataGrid ItemsSource="{Binding CodigosGerados}" MaxHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código"
                                                Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                            <DataGridTextColumn Header="Especialidade" Binding="{Binding Especialidade}" Width="*" />
                            <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="0.7*" />
                            <DataGridTextColumn Header="Faturar em" Binding="{Binding DataPrevistaFaturamento}" Width="*" />
                            <DataGridTextColumn Header="Como obter"
                                                Binding="{Binding FormaObtencao, Converter={StaticResource EnumDescricao}}" Width="1.3*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <ItemsControl ItemsSource="{Binding Avisos}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AlertaAviso}" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
