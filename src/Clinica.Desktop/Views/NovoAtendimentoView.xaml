<UserControl x:Class="Clinica.Desktop.Views.NovoAtendimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,24,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Novo atendimento" Style="{StaticResource H2}" />

                <TextBlock Text="Buscar paciente (nome ou CPF)" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox ItemsSource="{Binding Pacientes}" SelectedItem="{Binding PacienteSelecionado}"
                         DisplayMemberPath="Nome" Height="130" Margin="0,6,0,4" />
                <TextBlock Text="{Binding PacienteSelecionado.Nome, StringFormat='Selecionado: {0}'}"
                           Foreground="#14532D" FontWeight="SemiBold" Margin="0,0,0,8" />

                <TextBlock Text="Data" Style="{StaticResource Rotulo}" />
                <DatePicker SelectedDate="{Binding Data}" />

                <TextBlock Text="Modalidade" Style="{StaticResource Rotulo}" />
                <ComboBox ItemsSource="{Binding Modalidades}" SelectedItem="{Binding Modalidade}" />

                <TextBlock Text="Observações" Style="{StaticResource Rotulo}" />
                <TextBox Text="{Binding Observacoes}" AcceptsReturn="True" Height="56" TextWrapping="Wrap" />

                <Button Content="Lançar e gerar códigos" Command="{Binding LancarCommand}" Margin="0,14,0,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Códigos gerados" Style="{StaticResource H1}" />
            <DataGrid ItemsSource="{Binding CodigosGerados}" MaxHeight="280">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                    <DataGridTextColumn Header="Especialidade" Binding="{Binding Especialidade}" Width="*" />
                    <DataGridTextColumn Header="Ordem" Binding="{Binding Ordem}" Width="0.7*" />
                    <DataGridTextColumn Header="Faturar em" Binding="{Binding DataPrevistaFaturamento}" Width="*" />
                    <DataGridTextColumn Header="Como obter"
                                        Binding="{Binding FormaObtencao, Converter={StaticResource EnumDescricao}}" Width="1.3*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="Avisos" Style="{StaticResource H2}" />
            <ItemsControl ItemsSource="{Binding Avisos}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FEF3C7" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
